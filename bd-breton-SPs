GO    CREATE PROCEDURE [dbo].[sp_AddExpense]  (      @ProjectId         UNIQUEIDENTIFIER,      @UserEmail         VARCHAR(255),        @ExpenseTypeCode   VARCHAR(50),       -- viene de expense_types.code      @Description       NVARCHAR(500),      @Amount            DECIMAL(10,2),      @Currency          VARCHAR(3)         = NULL,      @ExpenseDate       DATE,              -- fecha del gasto        @VendorName        NVARCHAR(200)      = NULL,      @ReceiptNumber     VARCHAR(100)       = NULL,        @Notes             NVARCHAR(MAX)      = NULL,      @Status            VARCHAR(50)        = 'approved'  -- estado inicial  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validar usuario (por email) y tipo de gasto (por code)      -------------------------------------------------------------------      DECLARE          @UserId        UNIQUEIDENTIFIER,          @ExpenseTypeId INT;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END        SELECT @ExpenseTypeId = id      FROM expense_types      WHERE code = @ExpenseTypeCode        AND is_active = 1;        IF @ExpenseTypeId IS NULL      BEGIN          RAISERROR('Tipo de gasto no válido.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Insertar gasto      -------------------------------------------------------------------      DECLARE          @NewExpenseId UNIQUEIDENTIFIER = NEWID(),          @NowUtc       DATETIME2        = SYSUTCDATETIME();        INSERT INTO expenses      (          id,          project_id,          user_id,          expense_type_id,          description,          amount,          currency,          expense_date,          vendor_name,          receipt_number,          status,          approved_by,          approved_at,          rejection_reason,          reimbursed_at,          reimbursement_reference,          notes,          is_active,          created_at,          updated_at,          created_by,          updated_by      )      VALUES      (          @NewExpenseId,          @ProjectId,          @UserId,          @ExpenseTypeId,          @Description,          @Amount,          @Currency,          @ExpenseDate,          @VendorName,          @ReceiptNumber,          @Status,          NULL,          -- approved_by          NULL,          -- approved_at          NULL,          -- rejection_reason          NULL,          -- reimbursed_at          NULL,          -- reimbursement_reference          @Notes,          1,             -- is_active          @NowUtc,          @NowUtc,          @UserId,       -- created_by          @UserId        -- updated_by      );        -------------------------------------------------------------------      -- 3. Devolver gasto creado con info de usuario y tipo      -------------------------------------------------------------------      SELECT          e.id                    AS expense_id,          e.project_id,          e.user_id,          u.first_name + ' ' + u.last_name AS user_full_name,          u.email                 AS user_email,            e.expense_type_id,          et.code                 AS expense_type_code,          et.name                 AS expense_type_name,          et.icon                 AS expense_type_icon,          et.requires_receipt,          et.max_amount,            e.description,          e.amount,          e.currency,          e.expense_date,          e.vendor_name,          e.receipt_number,          e.status,            e.notes,          e.is_active,          e.created_at,          e.updated_at,            CAST(0 AS INT)              AS attachments_count,          CAST(NULL AS VARCHAR(500))  AS first_attachment_url,          CAST(NULL AS VARCHAR(500))  AS first_thumbnail_url      FROM expenses e      INNER JOIN users         u  ON u.id  = e.user_id      INNER JOIN expense_types et ON et.id = e.expense_type_id      WHERE e.id = @NewExpenseId;  END;  
GO    CREATE PROCEDURE [dbo].[sp_AddExpenseAttachment]  (      @ExpenseId        UNIQUEIDENTIFIER,      @FileName         NVARCHAR(255),      @FileUrl          VARCHAR(500),      @FileType         VARCHAR(100)    = NULL,      @FileSize         INT             = NULL,      @ThumbnailUrl     VARCHAR(500)    = NULL,      @IsReceipt        BIT             = NULL,  -- 1 si es boleta/factura      @SortOrder        INT             = 0,      @UploadedByEmail  VARCHAR(255)    = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validar que el gasto exista y esté activo      -------------------------------------------------------------------      IF NOT EXISTS (          SELECT 1          FROM expenses          WHERE id = @ExpenseId            AND is_active = 1      )      BEGIN          RAISERROR('El gasto especificado no existe o no está activo.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Obtener usuario que sube el archivo (si se envía email)      -------------------------------------------------------------------      DECLARE @UploadedByUserId UNIQUEIDENTIFIER = NULL;        IF @UploadedByEmail IS NOT NULL      BEGIN          SELECT @UploadedByUserId = id          FROM users          WHERE email = @UploadedByEmail            AND is_active = 1;          -- Si no lo encuentra, lo dejamos NULL      END        -------------------------------------------------------------------      -- 3. Insertar attachment      -------------------------------------------------------------------      DECLARE          @NewAttachmentId UNIQUEIDENTIFIER = NEWID(),          @NowUtc          DATETIME2        = SYSUTCDATETIME();        INSERT INTO expense_attachments      (          id,          expense_id,          file_name,          file_url,          file_size,          file_type,          thumbnail_url,          is_receipt,          sort_order,          is_active,          created_at,          uploaded_by      )      VALUES      (          @NewAttachmentId,          @ExpenseId,          @FileName,          @FileUrl,          @FileSize,          @FileType,          @ThumbnailUrl,          @IsReceipt,          ISNULL(@SortOrder, 0),          1,          @NowUtc,          @UploadedByUserId      );        -------------------------------------------------------------------      -- 4. Devolver attachment insertado      -------------------------------------------------------------------      SELECT          ea.id            AS attachment_id,          ea.expense_id,          ea.file_name,          ea.file_url,          ea.file_size,          ea.file_type,          ea.thumbnail_url,          ea.is_receipt,          ea.sort_order,          ea.is_active,          ea.created_at,          ea.uploaded_by,          u.email          AS uploaded_by_email,          u.first_name + ' ' + u.last_name AS uploaded_by_full_name      FROM expense_attachments ea      LEFT JOIN users u ON u.id = ea.uploaded_by      WHERE ea.id = @NewAttachmentId;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_AddNoteAttachment]  (      @NoteId           UNIQUEIDENTIFIER,      @FileName         NVARCHAR(255),      @FileUrl          VARCHAR(500),      @FileType         VARCHAR(100)    = NULL,  -- e.g. 'image/jpeg'      @FileSize         INT             = NULL,  -- en bytes      @ThumbnailUrl     VARCHAR(500)    = NULL,      @SortOrder        INT             = 0,      @UploadedByEmail  VARCHAR(255)    = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validar que la nota exista y esté activa      -------------------------------------------------------------------      IF NOT EXISTS (          SELECT 1          FROM project_notes    WHERE id = @NoteId            AND is_active = 1      )      BEGIN          RAISERROR('La nota especificada no existe o no está activa.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Obtener usuario que sube el archivo (si se envía email)      -------------------------------------------------------------------      DECLARE @UploadedByUserId UNIQUEIDENTIFIER = NULL;        IF @UploadedByEmail IS NOT NULL      BEGIN          SELECT @UploadedByUserId = id          FROM users          WHERE email = @UploadedByEmail            AND is_active = 1;          -- Si no lo encuentra, dejamos NULL (no bloqueamos el insert)      END        -------------------------------------------------------------------      -- 3. Insertar attachment      -------------------------------------------------------------------      DECLARE           @NewAttachmentId UNIQUEIDENTIFIER = NEWID(),          @NowUtc          DATETIME2 = SYSUTCDATETIME();        INSERT INTO note_attachments (          id,          note_id,          file_name,          file_url,          file_size,          file_type,          thumbnail_url,          sort_order,          is_active,          created_at,          uploaded_by      )      VALUES (          @NewAttachmentId,          @NoteId,          @FileName,          @FileUrl,          @FileSize,          @FileType,          @ThumbnailUrl,          ISNULL(@SortOrder, 0),          1,          @NowUtc,          @UploadedByUserId      );        -------------------------------------------------------------------      -- 4. Devolver attachment insertado      -------------------------------------------------------------------      SELECT          na.id           AS attachment_id,          na.note_id,          na.file_name,          na.file_url,          na.file_size,          na.file_type,          na.thumbnail_url,          na.sort_order,          na.is_active,          na.created_at,          na.uploaded_by,          u.email        AS uploaded_by_email,          u.first_name + ' ' + u.last_name AS uploaded_by_full_name      FROM note_attachments na      LEFT JOIN users u ON u.id = na.uploaded_by      WHERE na.id = @NewAttachmentId;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_AddProjectNote]  (      @ProjectId           UNIQUEIDENTIFIER,      @UserEmail           VARCHAR(255),      @ObservationTypeCode VARCHAR(50),      @Title               NVARCHAR(200) = NULL,      @Content             NVARCHAR(MAX),      @IsImportant         BIT = 0,      @IsVisibleToClient   BIT = 0  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas: usuario y tipo de observación      -------------------------------------------------------------------      DECLARE           @UserId UNIQUEIDENTIFIER,          @ObservationTypeId INT;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END        SELECT @ObservationTypeId = id      FROM observation_types      WHERE code = @ObservationTypeCode        AND is_active = 1;        IF @ObservationTypeId IS NULL      BEGIN          RAISERROR('Tipo de observación no válido.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Insertar nota      -------------------------------------------------------------------      DECLARE           @NewNoteId UNIQUEIDENTIFIER = NEWID(),          @NowUtc    DATETIME2 = SYSUTCDATETIME();        INSERT INTO project_notes (          id,          project_id,          user_id,          observation_type_id,          title,          content,          is_important,          is_visible_to_client,          is_active,          created_at,          updated_at,          created_by,          updated_by      )      VALUES (          @NewNoteId,          @ProjectId,          @UserId,          @ObservationTypeId,          @Title,          @Content,          @IsImportant,          @IsVisibleToClient,          1,          @NowUtc,          @NowUtc,          @UserId,          @UserId      );        -------------------------------------------------------------------      -- 3. Devolver la nota creada con info de usuario y tipo      -------------------------------------------------------------------      SELECT          pn.id                    AS note_id,          pn.project_id,          pn.user_id,          u.first_name + ' ' + u.last_name AS user_full_name,          u.email                 AS user_email,          pn.observation_type_id,          ot.code                 AS observation_type_code,          ot.name                 AS observation_type_name,          ot.color                AS observation_type_color,          ot.icon                 AS observation_type_icon,          pn.title,          pn.content,          pn.is_important,          pn.is_visible_to_client,          pn.is_active,          pn.created_at,          pn.updated_at,          CAST(0 AS INT)          AS attachments_count,          CAST(NULL AS VARCHAR(500)) AS first_attachment_url,          CAST(NULL AS VARCHAR(500)) AS first_thumbnail_url      FROM project_notes pn      INNER JOIN users u ON u.id = pn.user_id      INNER JOIN observation_types ot ON ot.id = pn.observation_type_id      WHERE pn.id = @NewNoteId;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_Attendance_ByEmployeeWeek]  (      @WeekEnd    DATE,      @UserEmail  NVARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        -- =============================================      -- 1. Resolver caller      -- =============================================      DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        -- =============================================      -- 2. Verificar user_module_permissions módulo 5      -- =============================================      DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        -- =============================================      -- 3. Resolver data_scope desde role_default_permissions      -- =============================================      DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        -- =============================================      -- 4. Sin permiso → tabla vacía sin error      -- =============================================      IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS user_id,              CAST(NULL AS NVARCHAR(200))    AS employee_name,              CAST(NULL AS VARCHAR(255))     AS email,              CAST(NULL AS INT)              AS projects_count,              CAST(NULL AS DECIMAL(10,2))    AS week_total_hours_num,              CAST(NULL AS DECIMAL(18,2))    AS week_total_payments,              CAST(NULL AS BIT)              AS IsExpanded          WHERE 1 = 0;          RETURN;      END        -- =============================================      -- 5. Query principal con filtro de data_scope      -- =============================================      DECLARE @WeekStart DATE = DATEADD(DAY, -6, @WeekEnd);        ;WITH TimeBase AS      (          SELECT              te.user_id,              te.project_id,              te.billable_hours,              te.hourly_rate,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[projects] p ON p.id = te.project_id          WHERE              te.is_active          = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @WeekStart AND @WeekEnd              -- Filtro data_scope              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      ),      ByEmployee AS      (          SELECT              tb.user_id,              COUNT(DISTINCT tb.project_id) AS total_projects,              SUM(tb.billable_hours)        AS total_hours,              SUM(tb.total_amount)          AS total_amount          FROM TimeBase tb          GROUP BY tb.user_id      )        SELECT          u.id                                          AS user_id,          u.first_name + N' ' + u.last_name            AS employee_name,          u.email,          ISNULL(be.total_projects, 0)                 AS projects_count,          CAST(ISNULL(be.total_hours,  0) AS DECIMAL(10,2)) AS week_total_hours_num,          CAST(ISNULL(be.total_amount, 0) AS DECIMAL(18,2)) AS week_total_payments,          CAST(1 AS BIT)                               AS IsExpanded      FROM ByEmployee be      INNER JOIN [dbo].[users] u ON u.id = be.user_id      ORDER BY          u.last_name,          u.first_name;    END;  
GO  CREATE   PROCEDURE [dbo].[sp_Attendance_ByEmployeeWeekChildren]  (      @WeekEnd    DATE,      @UserEmail  NVARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS user_id,              CAST(NULL AS NVARCHAR(200))    AS employee_name,              CAST(NULL AS VARCHAR(255))     AS email,              CAST(NULL AS VARCHAR(50))      AS employee_role,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS NVARCHAR(100))    AS city,              CAST(NULL AS VARCHAR(50))      AS state,              CAST(NULL AS VARCHAR(50))      AS color,              CAST(NULL AS DECIMAL(10,2))    AS sun_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS mon_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS tue_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS wed_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS thu_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS fri_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS sat_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS week_total_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS avg_hourly_rate_week,              CAST(NULL AS DECIMAL(18,2))    AS week_total_payments          WHERE 1 = 0;          RETURN;      END        DECLARE @WeekStart DATE = DATEADD(DAY, -6, @WeekEnd);        ;WITH TimeBase AS      (          SELECT              te.user_id,              te.project_id,              te.billable_hours,              te.hourly_rate,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[projects] p ON p.id = te.project_id          WHERE              te.is_active          = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @WeekStart AND @WeekEnd              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      )        SELECT          tb.user_id,          u.first_name + N' ' + u.last_name            AS employee_name,          u.email,          pa.role                                      AS employee_role,          tb.project_id,          p.code                                       AS project_code,          p.name                                       AS project_name,          p.city,          p.state,          p.color,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = @WeekStart                  THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS sun_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS mon_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS tue_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS wed_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS thu_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS fri_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = @WeekEnd                    THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS sat_hours_num,          CAST(SUM(tb.billable_hours)                           AS DECIMAL(10,2)) AS week_total_hours_num,          CAST(AVG(NULLIF(tb.hourly_rate, 0))                   AS DECIMAL(10,2)) AS avg_hourly_rate_week,          CAST(ISNULL(SUM(tb.total_amount), 0)                  AS DECIMAL(18,2)) AS week_total_payments      FROM TimeBase tb      INNER JOIN [dbo].[users] u    ON u.id = tb.user_id      INNER JOIN [dbo].[projects] p ON p.id = tb.project_id      LEFT  JOIN [dbo].[project_assignments] pa          ON  pa.project_id = tb.project_id          AND pa.user_id    = tb.user_id          AND pa.is_active  = 1      GROUP BY          tb.user_id, u.first_name, u.last_name, u.email, pa.role,          tb.project_id, p.code, p.name, p.city, p.state, p.color      ORDER BY          u.last_name,          u.first_name,          p.name;    END;  
GO    CREATE   PROCEDURE [dbo].[sp_Attendance_ByProjectChildrenTable]  (      @FromDate  DATE,                     -- inclusive      @ToDate    DATE,                     -- inclusive      @Company   NVARCHAR(200) = NULL      -- opcional: filtrar por compañía  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones      -------------------------------------------------------------------      IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Base de time_entries por rango (zona NY, usando clock_out_time)      -------------------------------------------------------------------      ;WITH TimeBase AS      (          SELECT              te.id                AS time_entry_id,              te.project_id,              te.user_id,              te.billable_hours,              te.hourly_rate,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM dbo.time_entries te          INNER JOIN dbo.projects p ON p.id = te.project_id          WHERE              te.is_active = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @FromDate AND @ToDate              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )      ),      -------------------------------------------------------------------      -- 3. Resumen por proyecto + empleado (sin other_payments aún)      -------------------------------------------------------------------      TimeSummary AS      (          SELECT              tb.project_id,              tb.user_id,              COUNT(DISTINCT tb.work_date_ny)         AS entries,                -- días trabajados              ISNULL(SUM(tb.billable_hours), 0)       AS total_billable_hours,              ISNULL(SUM(tb.total_amount), 0)         AS total_payment,                -- rate promedio ponderado por horas              CASE                   WHEN SUM(tb.billable_hours) IS NULL OR SUM(tb.billable_hours) = 0                      THEN NULL                  ELSE CAST(SUM(tb.total_amount) / SUM(tb.billable_hours) AS DECIMAL(10,2))              END                                      AS avg_rate,                -- horas promedio por día (para "AVERAGE HOURS")              CASE                   WHEN COUNT(DISTINCT tb.work_date_ny) = 0                      THEN NULL                  ELSE CAST(                          SUM(tb.billable_hours)                           / COUNT(DISTINCT tb.work_date_ny)                          AS DECIMAL(10,2)                       )              END                                      AS avg_hours_per_day          FROM TimeBase tb          GROUP BY              tb.project_id,              tb.user_id      ),      -------------------------------------------------------------------      -- 4. Refunds / deductions por proyecto + empleado en el mismo rango      -------------------------------------------------------------------      RDBase AS      (          SELECT              rd.project_id,              rd.user_id,              rd.type,              rd.amount,              rd.effective_date          FROM dbo.refunds_deductions rd          INNER JOIN dbo.projects p ON p.id = rd.project_id          WHERE              rd.is_active = 1              AND rd.effective_date BETWEEN @FromDate AND @ToDate              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )      ),      RDSummary AS      (          SELECT              r.project_id,              r.user_id,              SUM(                  CASE                      WHEN r.type = 'deduction'            THEN -r.amount                      WHEN r.type IN ('refund','addition') THEN  r.amount                      ELSE 0                  END              ) AS other_payments          FROM RDBase r          GROUP BY              r.project_id,              r.user_id      )        -------------------------------------------------------------------      -- 5. Resultado final: una fila por proyecto + empleado      -------------------------------------------------------------------      SELECT          ts.project_id,          p.code                           AS project_code,          p.name                           AS project_name,            ts.user_id,          u.first_name + N' ' + u.last_name AS employee_name,          u.email,            pa.role                           AS employee_role,            ts.entries,          ts.avg_rate,          ts.total_billable_hours,          ts.total_payment,          ts.avg_hours_per_day,            ISNULL(rd.other_payments, 0)      AS other_payments,          ts.total_payment + ISNULL(rd.other_payments, 0) AS grand_total      FROM TimeSummary ts      INNER JOIN dbo.projects p ON p.id = ts.project_id      INNER JOIN dbo.users   u  ON u.id = ts.user_id      LEFT  JOIN dbo.project_assignments pa             ON pa.project_id = ts.project_id            AND pa.user_id    = ts.user_id            AND pa.is_active  = 1      LEFT  JOIN RDSummary rd             ON rd.project_id = ts.project_id            AND rd.user_id    = ts.user_id      ORDER BY          p.name,          u.last_name,          u.first_name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_Attendance_ProjectsSummaryByRange]  (      @FromDate  DATE,                     -- inclusive      @ToDate    DATE,                     -- inclusive      @Company   NVARCHAR(200) = NULL      -- opcional: filtrar por compañía  )  AS  BEGIN      SET NOCOUNT ON;        IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        ;WITH Base AS      (          SELECT              te.id,              te.user_id,              te.project_id,              te.billable_hours,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM dbo.time_entries te          WHERE              te.is_active = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @FromDate AND @ToDate      )      SELECT          p.id              AS project_id,          p.code            AS project_code,          p.name            AS project_name,          p.city,          p.state,          p.company,          p.color,                              -- color del proyecto            COUNT(DISTINCT b.user_id)              AS total_employees,          ISNULL(SUM(b.billable_hours), 0)       AS total_billable_hours,          ISNULL(SUM(b.total_amount), 0)         AS total_revenue,            CAST(1 AS bit) AS IsExpanded           -- siempre FALSE al cargar      FROM Base b      INNER JOIN dbo.projects p ON p.id = b.project_id      WHERE          @Company IS NULL          OR LTRIM(RTRIM(@Company)) = N''          OR p.company = @Company      GROUP BY          p.id, p.code, p.name, p.city, p.state, p.company, p.color      ORDER BY          p.name;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_Attendance_WeeklyAnalysis]  (      @WeekEnd    DATE,      @UserEmail  NVARCHAR(255),      @Company    NVARCHAR(200) = NULL  )  AS  BEGIN      SET NOCOUNT ON;        IF @WeekEnd IS NULL      BEGIN          RAISERROR('WeekEnd es obligatorio.', 16, 1);          RETURN;      END;        DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS NVARCHAR(100))    AS city,              CAST(NULL AS VARCHAR(50))      AS state,              CAST(NULL AS VARCHAR(50))      AS company,              CAST(NULL AS VARCHAR(50))      AS color,              CAST(NULL AS BIT)              AS IsExpanded,              CAST(NULL AS INT)              AS unique_employees,              CAST(NULL AS DECIMAL(10,2))    AS total_hours,              CAST(NULL AS DECIMAL(18,2))    AS total_payable_amount          WHERE 1 = 0;          RETURN;      END        DECLARE @WeekStart DATE = DATEADD(DAY, -6, @WeekEnd);        ;WITH TimeBase AS      (          SELECT              te.project_id,              te.user_id,              te.billable_hours,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[projects] p ON p.id = te.project_id          WHERE              te.is_active          = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @WeekStart AND @WeekEnd              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      )        SELECT          p.id                                      AS project_id,          p.code                                    AS project_code,          p.name                                    AS project_name,          p.city,          p.state,          p.company,          p.color,          CAST(1 AS BIT)                            AS IsExpanded,          COUNT(DISTINCT tb.user_id)                AS unique_employees,          ISNULL(SUM(tb.billable_hours), 0)         AS total_hours,          ISNULL(SUM(tb.total_amount), 0)           AS total_payable_amount      FROM TimeBase tb      INNER JOIN [dbo].[projects] p ON p.id = tb.project_id      GROUP BY          p.id, p.code, p.name, p.city, p.state, p.company, p.color      ORDER BY          p.name;    END;  
GO  CREATE   PROCEDURE [dbo].[sp_Attendance_WeeklyAnalysisChildren]  (      @WeekEnd    DATE,      @UserEmail  NVARCHAR(255),      @Company    NVARCHAR(200) = NULL  )  AS  BEGIN      SET NOCOUNT ON;        IF @WeekEnd IS NULL      BEGIN          RAISERROR('WeekEnd es obligatorio.', 16, 1);          RETURN;      END;        DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS UNIQUEIDENTIFIER) AS user_id,              CAST(NULL AS NVARCHAR(200))    AS employee_name,              CAST(NULL AS VARCHAR(255))     AS email,              CAST(NULL AS VARCHAR(50))      AS employee_role,              CAST(NULL AS DECIMAL(10,2))    AS sun_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS mon_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS tue_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS wed_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS thu_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS fri_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS sat_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS week_total_hours_num,              CAST(NULL AS DECIMAL(10,2))    AS avg_hourly_rate_week,              CAST(NULL AS DECIMAL(18,2))    AS total_payment_week,              CAST(NULL AS NVARCHAR(20))     AS sun_hours_text,              CAST(NULL AS NVARCHAR(20))     AS mon_hours_text,              CAST(NULL AS NVARCHAR(20))     AS tue_hours_text,              CAST(NULL AS NVARCHAR(20))     AS wed_hours_text,              CAST(NULL AS NVARCHAR(20))     AS thu_hours_text,              CAST(NULL AS NVARCHAR(20))     AS fri_hours_text,              CAST(NULL AS NVARCHAR(20))     AS sat_hours_text,              CAST(NULL AS NVARCHAR(20))     AS week_total_text          WHERE 1 = 0;          RETURN;      END        DECLARE @WeekStart DATE = DATEADD(DAY, -6, @WeekEnd);        ;WITH TimeBase AS      (          SELECT              te.project_id,              te.user_id,              te.billable_hours,              te.hourly_rate,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[projects] p ON p.id = te.project_id          WHERE              te.is_active          = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @WeekStart AND @WeekEnd              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      )        SELECT          tb.project_id,          p.code                                    AS project_code,          p.name                                    AS project_name,          tb.user_id,          u.first_name + N' ' + u.last_name         AS employee_name,          u.email,          pa.role                                   AS employee_role,            CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = @WeekStart                  THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS sun_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS mon_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS tue_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS wed_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS thu_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS fri_hours_num,          CAST(ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,6,@WeekStart)   THEN tb.billable_hours END), 0) AS DECIMAL(10,2)) AS sat_hours_num,          CAST(ISNULL(SUM(tb.billable_hours), 0)                                                                   AS DECIMAL(10,2)) AS week_total_hours_num,          CAST(AVG(NULLIF(tb.hourly_rate, 0))                                                                      AS DECIMAL(10,2)) AS avg_hourly_rate_week,          CAST(ISNULL(SUM(tb.total_amount), 0)                                                                     AS DECIMAL(18,2)) AS total_payment_week,            -- Textos por día (domingo a sábado)          CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = @WeekStart THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = @WeekStart THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = @WeekStart THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = @WeekStart THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS sun_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,1,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS mon_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,2,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS tue_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,3,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS wed_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,4,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS thu_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,5,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS fri_hours_text,            CASE WHEN ISNULL(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,6,@WeekStart) THEN tb.billable_hours END), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,6,@WeekStart) THEN tb.billable_hours END) * 60.0) / 60), CASE WHEN FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,6,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(CASE WHEN tb.work_date_ny = DATEADD(DAY,6,@WeekStart) THEN tb.billable_hours END) * 60.0) % 60, N'm') END)          END AS sat_hours_text,            CASE WHEN ISNULL(SUM(tb.billable_hours), 0) = 0 THEN N'-'               ELSE CONCAT(FLOOR(FLOOR(SUM(tb.billable_hours) * 60.0) / 60), CASE WHEN FLOOR(SUM(tb.billable_hours) * 60.0) % 60 = 0 THEN N'h' ELSE CONCAT(N'h ', FLOOR(SUM(tb.billable_hours) * 60.0) % 60, N'm') END)          END AS week_total_text        FROM TimeBase tb      INNER JOIN [dbo].[projects] p ON p.id = tb.project_id      INNER JOIN [dbo].[users]    u ON u.id = tb.user_id      LEFT  JOIN [dbo].[project_assignments] pa             ON pa.project_id = tb.project_id            AND pa.user_id    = tb.user_id            AND pa.is_active  = 1      GROUP BY          tb.project_id, p.code, p.name,          tb.user_id, u.first_name, u.last_name, u.email, pa.role      ORDER BY          p.name,          u.last_name,          u.first_name;    END;  
GO    CREATE PROCEDURE [dbo].[sp_CreateProject]      @code                VARCHAR(50),      @name                NVARCHAR(200),      @client_email        VARCHAR(255),         -- correo del usuario logueado en PowerApps      @client_id           UNIQUEIDENTIFIER = NULL,      @description         NVARCHAR(MAX) = NULL,      @city                NVARCHAR(100),      @state               NVARCHAR(50),      @address             NVARCHAR(500),      @start_date          DATE,      @estimated_end_date  DATE = NULL,      @company             VARCHAR(50),      @status_id           INT = NULL,      @project_type_id     INT = NULL,      -- OPCIONALES:      @color               VARCHAR(50) = NULL,      @latitude            DECIMAL(10,8) = NULL,      @longitude           DECIMAL(11,8) = NULL,      @budget_hours        DECIMAL(10,2) = NULL,      @budget_amount       DECIMAL(15,2) = NULL,      @hourly_rate         DECIMAL(10,2) = NULL,      @is_active           BIT = 1,      @google_maps_link    NVARCHAR(500) = NULL, -- NUEVO      @zipcode             NVARCHAR(20)  = NULL, -- NUEVO      -- SALIDAS:      @new_id              UNIQUEIDENTIFIER OUTPUT,      @success             BIT OUTPUT,      @message             NVARCHAR(400) OUTPUT  AS  BEGIN      SET NOCOUNT ON;        BEGIN TRY          -----------------------------------------------------          -- 0. Buscar usuario por email (tabla dbo.users)          -----------------------------------------------------          DECLARE @created_by UNIQUEIDENTIFIER;            SELECT @created_by = u.id          FROM dbo.users u          WHERE u.email = @client_email            AND (u.is_active = 1 OR u.is_active IS NULL);            IF @created_by IS NULL          BEGIN              SET @success = 0;              SET @message = N'No se encontró un usuario válido con el correo especificado.';              SET @new_id  = NULL;              RETURN;          END;            -----------------------------------------------------          -- 1. Validar que el código no exista          -----------------------------------------------------          IF EXISTS (SELECT 1 FROM dbo.projects WHERE code = @code)          BEGIN              SET @success = 0;              SET @message = N'El código de proyecto ya existe.';              SET @new_id  = NULL;              RETURN;          END;            -----------------------------------------------------          -- 2. Generar nuevo GUID          -----------------------------------------------------          DECLARE @id UNIQUEIDENTIFIER = NEWID();            -----------------------------------------------------          -- 3. Insertar el proyecto          -----------------------------------------------------          INSERT INTO dbo.projects (              id,              code,              name,              description,              client_id,              status_id,              color,              address,              city,              latitude,              longitude,              start_date,              estimated_end_date,              actual_end_date,              budget_hours,              budget_amount,              hourly_rate,              progress_percentage,              is_active,              created_at,              updated_at,              created_by,              updated_by,              project_type_id,              state,              company,              google_maps_link,   -- NUEVO              zipcode             -- NUEVO          )          VALUES (              @id,              @code,              @name,              @description,              @client_id,              @status_id,              @color,              @address,              @city,              @latitude,              @longitude,              @start_date,              @estimated_end_date,              NULL,               -- actual_end_date              @budget_hours,              @budget_amount,              @hourly_rate,              0,                  -- progress_percentage inicial              @is_active,              SYSDATETIME(),      -- created_at              SYSDATETIME(),      -- updated_at              @created_by,              @created_by,        -- updated_by igual al creador al inicio              @project_type_id,              @state,              @company,              @google_maps_link,  -- NUEVO              @zipcode            -- NUEVO          );            SET @new_id  = @id;          SET @success = 1;          SET @message = N'Proyecto creado correctamente.';      END TRY      BEGIN CATCH          SET @success = 0;          SET @new_id  = NULL;          SET @message = ERROR_MESSAGE();      END CATCH;  END;  
GO    CREATE PROCEDURE [dbo].[sp_CreateProjectAssignment]  (      @ProjectId         UNIQUEIDENTIFIER,      @UserId            UNIQUEIDENTIFIER,      @HourlyRate        DECIMAL(10,2),      @Role              VARCHAR(50) = NULL,      @CreatedByUserId   UNIQUEIDENTIFIER = NULL  -- opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF NOT EXISTS (SELECT 1 FROM dbo.projects WHERE id = @ProjectId AND is_active = 1)      BEGIN          RAISERROR('Proyecto no encontrado o inactivo.', 16, 1);          RETURN;      END;        IF NOT EXISTS (SELECT 1 FROM dbo.users WHERE id = @UserId AND is_active = 1)      BEGIN          RAISERROR('Usuario no encontrado o inactivo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Verificar si ya existe una asignación para ese proyecto + usuario      -------------------------------------------------------------------      DECLARE @ExistingAssignmentId UNIQUEIDENTIFIER;        SELECT @ExistingAssignmentId = pa.id      FROM dbo.project_assignments pa      WHERE pa.project_id = @ProjectId        AND pa.user_id    = @UserId;        DECLARE @NowUtc DATETIME2 = SYSUTCDATETIME();      DECLARE @Today  DATE      = CAST(@NowUtc AS DATE);      DECLARE @FinalAssignmentId UNIQUEIDENTIFIER;        -------------------------------------------------------------------      -- 3. Si existe, reactivamos y actualizamos; si no, creamos un nuevo registro      -------------------------------------------------------------------      IF @ExistingAssignmentId IS NOT NULL      BEGIN          -- Reactivar y actualizar assignment existente          UPDATE pa          SET               pa.role        = @Role,              pa.hourly_rate = @HourlyRate,              pa.is_active   = 1,              pa.assigned_date = @Today,              pa.updated_at  = @NowUtc,              pa.updated_by  = @CreatedByUserId          FROM dbo.project_assignments pa          WHERE pa.id = @ExistingAssignmentId;            SET @FinalAssignmentId = @ExistingAssignmentId;      END      ELSE      BEGIN          -- Crear asignación nueva          DECLARE @NewId UNIQUEIDENTIFIER = NEWID();          SET @FinalAssignmentId = @NewId;            INSERT INTO dbo.project_assignments          (              id,              project_id,              user_id,              role,              hourly_rate,              assigned_date,              end_date,              is_active,              created_at,              updated_at,              created_by,              updated_by          )          VALUES          (              @NewId,              @ProjectId,              @UserId,              @Role,              @HourlyRate,              @Today,           -- assigned_date = hoy              NULL,             -- end_date              1,                -- is_active              @NowUtc,          -- created_at              NULL,             -- updated_at              @CreatedByUserId, -- created_by (puede ser NULL)              NULL              -- updated_by          );      END;        -------------------------------------------------------------------      -- 4. Devolver el registro resultante (nuevo o reactivado)      -------------------------------------------------------------------      SELECT          pa.id                AS assignment_id,          pa.project_id,          pa.user_id,          pa.role              AS assignment_role,          pa.hourly_rate       AS assignment_hourly_rate,          pa.assigned_date,          pa.end_date,          pa.is_active,          pa.created_at,          pa.updated_at,          pa.created_by,          pa.updated_by,            u.first_name,          u.last_name,          u.first_name + ' ' + u.last_name AS employee_name,          u.email           AS employee_email,          u.identification_number,          u.phone,          u.profile_photo_url,          u.role            AS user_role,          u.hourly_rate     AS user_hourly_rate,            p.name            AS project_name,          p.code            AS project_code      FROM dbo.project_assignments pa      INNER JOIN dbo.users    u ON u.id = pa.user_id      INNER JOIN dbo.projects p ON p.id = pa.project_id      WHERE pa.id = @FinalAssignmentId;  END;  
GO  CREATE   PROCEDURE dbo.sp_Expense_Update  (      @ExpenseId        UNIQUEIDENTIFIER,  -- id del gasto a actualizar      @ProjectId        UNIQUEIDENTIFIER,  -- nuevo proyecto (o el actual)      @UserEmail        VARCHAR(255),      -- email del usuario en PowerApps      @ExpenseTypeCode  VARCHAR(50),       -- código del tipo de gasto (ej: "TRAVEL")      @Description      NVARCHAR(500),      @Amount           DECIMAL(10,2),      @Currency         VARCHAR(3),      @ExpenseDate      DATE,              -- ya como DATE (convierte en PowerApps)      @Status           VARCHAR(50)        -- ej: "pending"  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener user_id por email      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = u.id      FROM dbo.users u      WHERE u.email = @UserEmail        AND (u.is_active = 1 OR u.is_active IS NULL);        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Obtener expense_type_id por código      -------------------------------------------------------------------      DECLARE @ExpenseTypeId INT;        SELECT @ExpenseTypeId = et.id      FROM dbo.expense_types et      WHERE et.code = @ExpenseTypeCode;        IF @ExpenseTypeId IS NULL      BEGIN          RAISERROR('No se encontró un tipo de gasto con el código especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Verificar que el expense existe y está activo (opcional)      -------------------------------------------------------------------      IF NOT EXISTS (          SELECT 1          FROM dbo.expenses e          WHERE e.id = @ExpenseId            AND (e.is_active = 1 OR e.is_active IS NULL)      )      BEGIN          RAISERROR('No se encontró un expense activo con el Id especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 4. Actualizar el expense      -------------------------------------------------------------------      UPDATE dbo.expenses      SET          project_id      = @ProjectId,          user_id         = @UserId,          -- opcionalmente podrías no cambiarlo          expense_type_id = @ExpenseTypeId,          description     = @Description,          amount          = @Amount,          currency        = @Currency,          expense_date    = @ExpenseDate,          status          = @Status,          updated_at      = SYSDATETIME(),          updated_by      = @UserId      WHERE id = @ExpenseId;  END;  
GO  CREATE   PROCEDURE dbo.sp_ExpenseAttachments_DeactivateByIdsCsv  (      @IdsCsv VARCHAR(MAX)  -- Lista de GUIDs separados por comas  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Parsear CSV a tabla (requiere SQL Server 2016+ por STRING_SPLIT)      -------------------------------------------------------------------      ;WITH ParsedIds AS      (          SELECT              TRY_CAST(value AS UNIQUEIDENTIFIER) AS id          FROM STRING_SPLIT(@IdsCsv, ',')      )      UPDATE ea      SET ea.is_active = 0      FROM dbo.expense_attachments ea      INNER JOIN ParsedIds p          ON ea.id = p.id      WHERE p.id IS NOT NULL;  END;  
GO  CREATE   PROCEDURE dbo.sp_ExpenseAttachments_GetByExpenseId  (      @expense_id UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          id,          expense_id,          file_name,          file_url,          file_size,          file_type,          thumbnail_url,          is_receipt,          sort_order,          is_active,          created_at,          uploaded_by      FROM dbo.expense_attachments      WHERE expense_id = @expense_id        AND is_active = 1      ORDER BY sort_order, created_at;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_Expenses_InactiveFromUser]  (      @ExpenseId  UNIQUEIDENTIFIER,      @AdminEmail VARCHAR(255) = NULL  -- opcional: quién elimina  )  AS  BEGIN      SET NOCOUNT ON;        IF @ExpenseId IS NULL      BEGIN          RAISERROR('ExpenseId es obligatorio.', 16, 1);          RETURN;      END;        DECLARE @AdminId UNIQUEIDENTIFIER = NULL;        IF @AdminEmail IS NOT NULL AND LTRIM(RTRIM(@AdminEmail)) <> ''      BEGIN          SELECT @AdminId = id          FROM dbo.users          WHERE email = @AdminEmail            AND is_active = 1;      END;        -- Marcar como inactivo      UPDATE dbo.expenses      SET           is_active  = 0,          updated_at = SYSUTCDATETIME(),          updated_by = ISNULL(@AdminId, updated_by)      WHERE id = @ExpenseId;        -- Opcional: devolver la fila resultante (o nada)      SELECT *      FROM dbo.expenses      WHERE id = @ExpenseId;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetAllProjects]  AS  BEGIN      SET NOCOUNT ON;        SELECT          p.id                 AS project_id,          p.code               AS project_code,          p.name               AS project_name,          p.description,          p.client_id,          c.name               AS client_name,          p.status_id,          ps.code              AS status_code,          ps.name              AS status_name,          p.color,          p.address,          p.city,    p.state,          p.start_date,          p.estimated_end_date,          p.actual_end_date,          p.budget_hours,          p.budget_amount,          p.hourly_rate,          p.progress_percentage,          p.is_active,          p.created_at,          p.updated_at      FROM projects p      LEFT JOIN clients        c  ON c.id  = p.client_id      LEFT JOIN project_status ps ON ps.id = p.status_id      ORDER BY           p.is_active DESC,          p.name;  END;  
GO  CREATE PROCEDURE [dbo].[sp_GetAssignedProjectsByEmail]  (      @UserEmail VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener el usuario por email      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- No existe usuario con ese email, devolvemos un resultset vacío          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS NVARCHAR(MAX))    AS project_description,              CAST(NULL AS NVARCHAR(200))    AS client_name,              CAST(NULL AS VARCHAR(7))       AS project_color,              CAST(NULL AS NVARCHAR(500))    AS project_address,              CAST(NULL AS NVARCHAR(100))    AS project_city,              CAST(NULL AS DATE)             AS start_date,              CAST(NULL AS DATE)             AS estimated_end_date,              CAST(NULL AS DECIMAL(5,2))     AS progress_percentage,              CAST(NULL AS VARCHAR(50))      AS project_status_code,              CAST(NULL AS NVARCHAR(100))    AS project_status_name,              CAST(NULL AS VARCHAR(50))      AS project_state,        -- NUEVO              CAST(NULL AS VARCHAR(50))      AS assignment_role,              CAST(NULL AS DECIMAL(10,2))    AS assignment_hourly_rate,              CAST(NULL AS DATE)             AS assignment_date,              CAST(NULL AS BIT)              AS assignment_is_active,              CAST(NULL AS DECIMAL(10,2))    AS week_hours,              CAST(NULL AS DECIMAL(15,2))    AS week_amount          WHERE 1 = 0; -- truco para no devolver filas          RETURN;      END        -------------------------------------------------------------------      -- 2. Calcular semana actual (para totales opcionales)      -------------------------------------------------------------------      DECLARE           @Today          DATE       = CAST(GETUTCDATE() AS DATE),          @WeekStartDate  DATE,          @WeekEndDate    DATE;        -- Inicio de semana lunes      DECLARE @PrevDateFirst INT = @@DATEFIRST;      SET DATEFIRST 1; -- lunes        SET @WeekStartDate = DATEADD(DAY, -(DATEPART(WEEKDAY, @Today) - 1), @Today);      SET @WeekEndDate   = DATEADD(DAY, 6, @WeekStartDate);        SET DATEFIRST @PrevDateFirst;        -------------------------------------------------------------------      -- 3. Devolver proyectos asignados con info básica + horas semana actual      -------------------------------------------------------------------      ;WITH WeekTime AS      (          SELECT               te.project_id,              SUM(ISNULL(te.billable_hours, te.total_hours)) AS total_hours,              SUM(ISNULL(te.billable_hours, te.total_hours) * ISNULL(te.hourly_rate, 0)) AS total_amount          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND CAST(te.clock_in_time AS DATE) BETWEEN @WeekStartDate AND @WeekEndDate          GROUP BY te.project_id      )      SELECT           p.id                 AS project_id,          p.code               AS project_code,          p.name               AS project_name,          p.description        AS project_description,          c.name               AS client_name,          p.color              AS project_color,          p.address            AS project_address,          p.city               AS project_city,          p.start_date,          p.estimated_end_date,          p.progress_percentage,          ps.code              AS project_status_code,          ps.name              AS project_status_name,          p.state              AS project_state,         -- NUEVO            pa.role              AS assignment_role,          pa.hourly_rate       AS assignment_hourly_rate,          pa.assigned_date     AS assignment_date,          pa.is_active         AS assignment_is_active,            ISNULL(wt.total_hours, 0)   AS week_hours,          ISNULL(wt.total_amount, 0)  AS week_amount      FROM project_assignments pa      INNER JOIN projects          p  ON pa.project_id = p.id      LEFT  JOIN clients           c  ON p.client_id = c.id      LEFT  JOIN project_status    ps ON p.status_id = ps.id      LEFT  JOIN WeekTime          wt ON wt.project_id = p.id      WHERE           pa.user_id   = @UserId          AND pa.is_active = 1          AND p.is_active  = 1      ORDER BY           p.start_date DESC, p.name;    END;  
GO    CREATE   PROCEDURE dbo.sp_GetAvailableUsersForProject  (      @ProjectId UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          u.id                           AS user_id,          u.first_name,          u.last_name,          u.first_name + ' ' + u.last_name AS full_name,          u.role                         AS user_role,          u.hourly_rate,          u.identification_number,          u.email,          u.phone,          u.profile_photo_url,            -- Texto listo para mostrar en el dropdown          CONCAT(              u.first_name, ' ', u.last_name,              ' - ', ISNULL(u.role, ''),              ' - $', FORMAT(u.hourly_rate, '0.##'),              ' - ', ISNULL(u.identification_number, '')          ) AS display_text      FROM dbo.users u      WHERE          u.is_active = 1          AND NOT EXISTS          (              SELECT 1              FROM dbo.project_assignments pa              WHERE                   pa.project_id = @ProjectId                  AND pa.user_id = u.id                  AND (pa.is_active = 1 OR pa.is_active IS NULL)          )      ORDER BY          u.last_name,          u.first_name;  END;  
GO    CREATE PROCEDURE [dbo].[sp_GetCurrentUtcTime]  AS  BEGIN      SET NOCOUNT ON;        SELECT SYSUTCDATETIME() AS current_utc_datetime;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetDailyTimeEntriesSummary]  (      @WorkDate   DATE,      @UserEmail  NVARCHAR(255),      @ProjectId  UNIQUEIDENTIFIER = NULL,      @SearchText NVARCHAR(100)    = NULL,      @Company    NVARCHAR(200)    = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -- Resultado vacío reutilizable      DECLARE @EmptyResult BIT = 0;        -- =============================================      -- 1. Resolver el caller por email      -- =============================================      DECLARE @CallerId UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        -- =============================================      -- 2. Verificar user_module_permissions módulo 5      --    Solo confirma si puede ver la pantalla      -- =============================================      DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        -- =============================================      -- 3. Resolver data_scope desde role_default_permissions      --    usando el rol del usuario en la app      -- =============================================      DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            -- Sin configuración de rol para este módulo → sin datos          IF @DataScope IS NULL              SET @EmptyResult = 1;      END        -- =============================================      -- 4. Si no hay permiso → tabla vacía sin error      -- =============================================      IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS time_entry_id,              CAST(NULL AS UNIQUEIDENTIFIER) AS employee_id,              CAST(NULL AS NVARCHAR(200))    AS employee_name,              CAST(NULL AS VARCHAR(255))     AS employee_email,              CAST(NULL AS VARCHAR(50))      AS identification_number,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(50))      AS state,              CAST(NULL AS NVARCHAR(100))    AS city,              CAST(NULL AS VARCHAR(50))      AS company,              CAST(NULL AS VARCHAR(50))      AS employee_role,              CAST(NULL AS INT)              AS break_minutes,              CAST(NULL AS DATETIME2)        AS clock_in_time,              CAST(NULL AS DATETIME2)        AS clock_out_time,              CAST(NULL AS DECIMAL(10,8))    AS clock_in_latitude,              CAST(NULL AS DECIMAL(11,8))    AS clock_in_longitude,              CAST(NULL AS DECIMAL(10,8))    AS clock_out_latitude,              CAST(NULL AS DECIMAL(11,8))    AS clock_out_longitude,              CAST(NULL AS INT)              AS total_minutes,              CAST(NULL AS NVARCHAR(50))     AS total_label,              CAST(NULL AS NVARCHAR(50))     AS billable_time,              CAST(NULL AS NVARCHAR(50))     AS status_label,              CAST(NULL AS VARCHAR(500))     AS clock_in_photo_url,              CAST(NULL AS VARCHAR(500))     AS clock_out_photo_url          WHERE 1 = 0;          RETURN;      END        -- =============================================      -- 5. Construir el filtro de proyectos según scope      --    'all'               → todos los proyectos      --    'assigned_projects' → solo proyectos donde      --                          el caller es Project Manager      -- =============================================      DECLARE          @StartOfDay DATETIME2 = CAST(@WorkDate AS DATETIME2),          @EndOfDay   DATETIME2 = DATEADD(DAY, 1, CAST(@WorkDate AS DATETIME2));        ;WITH DayEntries AS      (          SELECT              te.id                  AS time_entry_id,              te.project_id,              te.user_id,              te.clock_in_time,              te.clock_out_time,              te.break_minutes,              te.total_hours,              te.billable_hours,              te.clock_in_photo_url,              te.clock_out_photo_url,              te.clock_in_latitude,              te.clock_in_longitude,              te.clock_out_latitude,              te.clock_out_longitude          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[projects] p ON p.id = te.project_id          WHERE              te.is_active = 1              AND te.clock_in_time >= @StartOfDay              AND te.clock_in_time <  @EndOfDay              -- Filtro opcional por proyecto              AND (                      @ProjectId IS NULL                   OR @ProjectId = '00000000-0000-0000-0000-000000000000'                   OR te.project_id = @ProjectId                  )              -- Filtro opcional por empresa              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )              -- Filtro por data_scope del rol              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      ),      EntryCalc AS      (          SELECT              de.*,              CASE                  WHEN de.clock_out_time IS NOT NULL                      THEN DATEDIFF(MINUTE, de.clock_in_time, de.clock_out_time)                  ELSE DATEDIFF(MINUTE, de.clock_in_time, SYSUTCDATETIME())              END AS total_minutes_calc,              CASE                  WHEN de.clock_out_time IS NULL THEN 1 ELSE 0              END AS is_open          FROM DayEntries de      )        SELECT          ec.time_entry_id,            u.id                              AS employee_id,          u.first_name + N' ' + u.last_name AS employee_name,          u.email                           AS employee_email,          u.identification_number,            p.id                              AS project_id,          p.name                            AS project_name,          p.code                            AS project_code,          p.state,          p.city,          p.company,            pa.role                           AS employee_role,            ec.break_minutes,          ec.clock_in_time,          ec.clock_out_time,          ec.clock_in_latitude,          ec.clock_in_longitude,          ec.clock_out_latitude,          ec.clock_out_longitude,            ec.total_minutes_calc             AS total_minutes,            CASE              WHEN ec.is_open = 1                  THEN N'En sitio'              ELSE CONCAT(                      (ec.total_minutes_calc / 60), N'h ',                      (ec.total_minutes_calc % 60), N'm'                   )          END AS total_label,            CASE              WHEN ec.is_open = 1                  THEN N'0h'              ELSE CONCAT(                      ((ec.total_minutes_calc - ec.break_minutes) / 60), N'h ',                      ((ec.total_minutes_calc - ec.break_minutes) % 60), N'm'                   )          END AS billable_time,            CASE              WHEN ec.is_open = 1 THEN N'En sitio'              ELSE N'Finalizada'          END AS status_label,            ec.clock_in_photo_url,          ec.clock_out_photo_url        FROM EntryCalc ec      INNER JOIN [dbo].[users]    u  ON u.id = ec.user_id      INNER JOIN [dbo].[projects] p  ON p.id = ec.project_id      LEFT  JOIN [dbo].[project_assignments] pa             ON pa.project_id = ec.project_id            AND pa.user_id    = ec.user_id            AND pa.is_active  = 1      WHERE          (              @SearchText IS NULL              OR LTRIM(RTRIM(@SearchText)) = N''              OR (u.first_name + N' ' + u.last_name) LIKE N'%' + @SearchText + N'%'              OR u.identification_number             LIKE N'%' + @SearchText + N'%'          )      ORDER BY          u.last_name,          u.first_name,          p.name;    END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetEmployeeProjectSummaryByRange]  (      @UserId    UNIQUEIDENTIFIER,      @FromDate  DATE,      @ToDate    DATE  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 0. Validaciones      -------------------------------------------------------------------      IF @UserId IS NULL      BEGIN          RAISERROR('UserId es obligatorio.', 16, 1);          RETURN;      END;        IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 1. CTE de time_entries en el rango (zona NY, usando clock_out_time)      -------------------------------------------------------------------      ;WITH TimeBase AS      (          SELECT              te.id,              te.project_id,              te.user_id,              te.clock_in_time,              te.clock_out_time,              te.billable_hours,              te.hourly_rate,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM dbo.time_entries te          WHERE              te.is_active = 1              AND te.user_id = @UserId              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) >= @FromDate              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) <= @ToDate      ),      -------------------------------------------------------------------      -- 2. Sumarios de time_entries por proyecto      -------------------------------------------------------------------      TimeSummary AS      (          SELECT              tb.project_id,              COUNT(DISTINCT tb.work_date_ny)           AS total_days_worked,              ISNULL(SUM(tb.billable_hours), 0)        AS total_billable_hours,              -- promedio simple del rate (debería ser único por proyecto-user)              CASE                   WHEN COUNT(tb.hourly_rate) = 0                      THEN NULL                  ELSE CAST(AVG(tb.hourly_rate) AS DECIMAL(10,2))              END                                      AS avg_hourly_rate,              ISNULL(SUM(tb.total_amount), 0)          AS total_amount          FROM TimeBase tb          GROUP BY tb.project_id      ),      -------------------------------------------------------------------      -- 3. Other payments por proyecto desde refunds_deductions      -------------------------------------------------------------------      RDBase AS      (          SELECT              rd.project_id,              rd.user_id,              rd.type,              rd.amount,              rd.effective_date          FROM dbo.refunds_deductions rd          WHERE              rd.is_active = 1              AND rd.user_id = @UserId              AND rd.effective_date >= @FromDate              AND rd.effective_date <= @ToDate     AND rd.status = 'approved'      ),      RDSummary AS      (          SELECT              r.project_id,              SUM(                  CASE                       WHEN r.type = 'deduction' THEN -r.amount                      WHEN r.type IN ('refund', 'addition') THEN  r.amount                      ELSE 0                  END              ) AS other_payments          FROM RDBase r          GROUP BY r.project_id      ),      -------------------------------------------------------------------      -- 4. Unir por proyecto y calcular totals por proyecto      -------------------------------------------------------------------      PerProject AS      (          SELECT              ts.project_id,              p.code  AS project_code,              p.name  AS project_name,     p.state AS project_state,     p.city  AS project_city,                ts.total_days_worked,              ts.total_billable_hours,              ts.avg_hourly_rate,              ts.total_amount,                ISNULL(rds.other_payments, 0) AS other_payments,                ts.total_amount + ISNULL(rds.other_payments, 0) AS grand_total          FROM TimeSummary ts          INNER JOIN dbo.projects p              ON p.id = ts.project_id          LEFT JOIN RDSummary rds              ON rds.project_id = ts.project_id      ),      -------------------------------------------------------------------      -- 5. Totales generales (fila resumen)      -------------------------------------------------------------------      GrandTotal AS      (          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              N'TOTAL'                       AS project_code,              N'TOTAL'                       AS project_name,        N'TOTAL'                       AS project_city,        N'TOTAL'        AS project_state,                SUM(total_days_worked)        AS total_days_worked,              SUM(total_billable_hours)     AS total_billable_hours,              NULL                          AS avg_hourly_rate, -- no aplica global              SUM(total_amount)             AS total_amount,              SUM(other_payments)           AS other_payments,              SUM(grand_total)              AS grand_total          FROM PerProject      )        -------------------------------------------------------------------      -- 6. Resultado final: proyectos + fila TOTAL      -------------------------------------------------------------------      SELECT          0 AS is_total_row,          pp.project_id,          pp.project_code,          pp.project_name,    pp.project_city,    pp.project_state,          pp.total_days_worked,          pp.total_billable_hours,          pp.avg_hourly_rate,          pp.total_amount,          pp.other_payments,          pp.grand_total      FROM PerProject pp        UNION ALL        SELECT          1 AS is_total_row,          gt.project_id,          gt.project_code,          gt.project_name,    gt.project_city,    gt.project_state,          gt.total_days_worked,          gt.total_billable_hours,          gt.avg_hourly_rate,          gt.total_amount,          gt.other_payments,          gt.grand_total      FROM GrandTotal gt        ORDER BY          is_total_row,      -- primero proyectos (0), luego TOTAL (1)          project_name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetExpensesList]  (      @FromDate      DATE              = NULL,   -- fecha inicio      @ToDate        DATE              = NULL,   -- fecha fin      @ProjectId     UNIQUEIDENTIFIER  = NULL,   -- filtro proyecto (NULL = todos)      @ExpenseTypeId INT               = NULL,   -- filtro categoría / tipo de gasto      @Status        VARCHAR(50)       = NULL,   -- 'pending','approved','rejected', NULL = todos      @SearchText    NVARCHAR(200)     = NULL    -- búsqueda en empleado, descripción, proyecto, cliente, DNI  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Normalizar rango de fechas      -------------------------------------------------------------------      DECLARE @StartDate DATE = ISNULL(@FromDate, '19000101');      DECLARE @EndDate   DATE = ISNULL(@ToDate,   '21000101');        -------------------------------------------------------------------      -- 2. CTE: attachments por gasto (una sola foto representativa)      -------------------------------------------------------------------      ;WITH AttachmentPerExpense AS      (          SELECT              ea.expense_id,              -- Tomamos el primer adjunto activo (puedes ajustar el criterio)              MIN(ea.file_url) AS file_url          FROM dbo.expense_attachments ea          WHERE ea.is_active = 1          GROUP BY ea.expense_id      ),      Base AS      (          SELECT              e.id              AS expense_id,              e.user_id,              e.project_id,              e.expense_type_id,              e.description,              e.amount,              e.currency,              e.expense_date,              e.status,              e.is_active,                u.first_name,              u.last_name,              u.first_name + ' ' + u.last_name AS employee_name,              u.email           AS employee_email,              u.identification_number,                p.name            AS project_name,              p.code            AS project_code,              c.name            AS client_name,                et.code           AS expense_type_code,              et.name           AS expense_type_name,              et.icon           AS expense_type_icon,                a.file_url        AS attachment_file_url   -- ID de blobstorage          FROM dbo.expenses e          INNER JOIN dbo.users         u  ON u.id  = e.user_id          INNER JOIN dbo.projects      p  ON p.id  = e.project_id          LEFT  JOIN dbo.clients       c  ON c.id  = p.client_id          LEFT  JOIN dbo.expense_types et ON et.id = e.expense_type_id          LEFT  JOIN AttachmentPerExpense a ON a.expense_id = e.id          WHERE              e.is_active = 1              AND e.expense_date >= @StartDate              AND e.expense_date <= @EndDate              AND (@ProjectId     IS NULL OR e.project_id      = @ProjectId)              AND (@ExpenseTypeId IS NULL OR e.expense_type_id = @ExpenseTypeId)              AND (@Status IS NULL OR @Status = '' OR e.status = @Status)              AND (                      @SearchText IS NULL                   OR LTRIM(RTRIM(@SearchText)) = N''                   OR (                          (u.first_name + N' ' + u.last_name) LIKE N'%' + @SearchText + N'%'                          OR u.identification_number LIKE N'%' + @SearchText + N'%'                          OR e.description LIKE N'%' + @SearchText + N'%'                          OR p.name  LIKE N'%' + @SearchText + N'%'                          OR p.code  LIKE N'%' + @SearchText + N'%'                          OR c.name  LIKE N'%' + @SearchText + N'%'                      )                  )      )      -------------------------------------------------------------------      -- 3. Resultado para la galería      -------------------------------------------------------------------      SELECT          b.expense_id,          b.expense_date,          b.amount,          b.currency,          b.status,          b.description,            b.user_id          AS employee_id,          b.employee_name,          b.employee_email,          b.identification_number,            b.project_id,          b.project_name,          b.project_code,          b.client_name,            b.expense_type_id,          b.expense_type_code,          b.expense_type_name,          b.expense_type_icon,            b.attachment_file_url      -- <-- ID de blobstorage de la foto      FROM Base b      ORDER BY           b.expense_date DESC,          b.employee_name,          b.project_name;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetExpenseTypes]  AS  BEGIN      SET NOCOUNT ON;        SELECT          et.id            AS expense_type_id,          et.code          AS expense_type_code,          et.name          AS expense_type_name,          et.description,          et.icon,          et.requires_receipt,          et.max_amount,          et.is_active,          et.created_at,          et.updated_at      FROM dbo.expense_types et      WHERE           et.is_active = 1          -- solo tipos activos para la app      ORDER BY           et.name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetMonthlyExpensesSummary]  AS  BEGIN      SET NOCOUNT ON;        DECLARE @Today    DATE = CAST(GETUTCDATE() AS DATE);      DECLARE @MonthIni DATE = DATEFROMPARTS(YEAR(@Today), MONTH(@Today), 1);      DECLARE @MonthEnd DATE = EOMONTH(@Today);        SELECT          ISNULL(SUM(CASE WHEN e.status = 'approved'   THEN e.amount ELSE 0 END), 0) AS total_approved,          ISNULL(SUM(CASE WHEN e.status = 'pending'    THEN e.amount ELSE 0 END), 0) AS total_pending,          ISNULL(SUM(CASE WHEN e.status = 'rejected'   THEN e.amount ELSE 0 END), 0) AS total_rejected,          ISNULL(SUM(CASE WHEN e.status NOT IN ('approved','pending','rejected')                           THEN e.amount ELSE 0 END), 0) AS total_other,          ISNULL(SUM(e.amount), 0) AS total_all      FROM expenses e      WHERE           e.is_active   = 1          AND e.expense_date >= @MonthIni          AND e.expense_date <= @MonthEnd;  END;  
GO    CREATE   PROCEDURE dbo.sp_GetNoteAttachmentsByNoteId  (      @NoteId UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          na.id,          na.note_id,          na.file_name,          na.file_url,          na.file_size,          na.file_type,          na.thumbnail_url,          na.sort_order,          na.is_active,          na.created_at,          na.uploaded_by      FROM dbo.note_attachments na      WHERE          na.note_id = @NoteId          AND (na.is_active = 1 OR na.is_active IS NULL)      ORDER BY          na.sort_order,          na.created_at;  END;  
GO  CREATE   PROCEDURE dbo.sp_GetProjectAssignmentsByProject  (      @ProjectId UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          pa.id                AS assignment_id,          pa.project_id,          pa.user_id,          pa.role              AS assignment_role,   -- rol específico en el proyecto          pa.hourly_rate       AS assignment_hourly_rate, -- por si quieres ver la diferencia          pa.assigned_date,          pa.end_date,          pa.is_active,          pa.created_at,          pa.updated_at,          pa.created_by,          pa.updated_by,            -- Datos del usuario (LO QUE QUIERES MOSTRAR)          u.first_name,          u.last_name,          u.first_name + ' ' + u.last_name AS employee_name,   -- nombre completo          u.email           AS employee_email,          u.identification_number,          u.phone,          u.profile_photo_url,          u.role            AS user_role,        -- rol del usuario (tabla users)          u.hourly_rate     AS user_hourly_rate, -- hourly_rate desde users            -- Datos del proyecto          p.name            AS project_name,          p.code            AS project_code      FROM dbo.project_assignments pa      INNER JOIN dbo.users    u ON u.id = pa.user_id      INNER JOIN dbo.projects p ON p.id = pa.project_id      WHERE          pa.project_id = @ProjectId          AND (pa.is_active = 1 OR pa.is_active IS NULL)      ORDER BY          u.last_name,          u.first_name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetProjectDashboardSummary]  AS  BEGIN      SET NOCOUNT ON;        SELECT          COUNT(*) AS total_projects,          SUM(CASE WHEN ps.code = 'on_going' THEN 1 ELSE 0 END)   AS total_in_progress,          SUM(CASE WHEN ps.code = 'paused'      THEN 1 ELSE 0 END)   AS total_paused,          SUM(CASE WHEN ps.code = 'completed'   THEN 1 ELSE 0 END)   AS total_completed,          SUM(CASE WHEN ps.code = 'not_yet_started' THEN 1 ELSE 0 END)   AS total_not_started,          SUM(CASE WHEN ps.code = 'permitting' THEN 1 ELSE 0 END)   AS total_permitting      FROM dbo.projects p      LEFT JOIN dbo.project_status ps ON ps.id = p.status_id      WHERE           p.is_active = 1;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetProjectExpensesForUser]  (      @UserEmail     VARCHAR(255),      @ProjectId     UNIQUEIDENTIFIER,      @ReferenceDate DATE = NULL   -- opcional: base para "Hoy/Ayer/Hace X días"  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- Usuario no encontrado: resultset vacío          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS expense_id,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(7))       AS project_color,              CAST(NULL AS INT)              AS expense_type_id,              CAST(NULL AS VARCHAR(50))      AS expense_type_code,              CAST(NULL AS NVARCHAR(100))    AS expense_type_name,              CAST(NULL AS VARCHAR(50))      AS expense_type_icon,              CAST(0    AS DECIMAL(10,2))    AS amount,              CAST(NULL AS VARCHAR(3))       AS currency,              CAST(NULL AS DATE)             AS expense_date,              CAST(NULL AS DATE)             AS created_at,              CAST(NULL AS VARCHAR(50))      AS status,              CAST(NULL AS NVARCHAR(500))    AS description,              CAST(0    AS BIT)              AS has_receipt,              CAST(NULL AS NVARCHAR(50))     AS relative_label,              CAST(0    AS DECIMAL(10,2))    AS total_expenses          WHERE 1 = 0;          RETURN;      END        -------------------------------------------------------------------      -- 2. Fecha de referencia para "Hoy / Ayer / Hace X días"      -------------------------------------------------------------------      DECLARE @RefDate DATE;      IF @ReferenceDate IS NULL          SET @RefDate = CAST(GETUTCDATE() AS DATE);      ELSE          SET @RefDate = @ReferenceDate;        -------------------------------------------------------------------      -- 3. CTE: gastos del usuario en el proyecto      -------------------------------------------------------------------      ;WITH UserProjectExpenses AS      (          SELECT               e.id             AS expense_id,              e.project_id,              e.user_id,              e.expense_type_id,              e.amount,              e.currency,              e.expense_date,              e.status,     e.created_at,              e.description,              DATEDIFF(DAY, e.expense_date, @RefDate) AS days_diff          FROM expenses e          WHERE               e.user_id = @UserId              AND e.project_id = @ProjectId              AND e.is_active = 1              -- opcional: excluir rechazados si no quieres mostrarlos              -- AND e.status <> 'rejected'      ),      Receipts AS      (          SELECT               ea.expense_id,              MAX(CASE WHEN ea.is_receipt = 1 THEN 1 ELSE 0 END) AS has_receipt          FROM expense_attachments ea          WHERE ea.is_active = 1          GROUP BY ea.expense_id      )      SELECT          upe.expense_id,          upe.project_id,          p.name               AS project_name,          p.code               AS project_code,          p.color              AS project_color,            et.id                AS expense_type_id,          et.code              AS expense_type_code,          et.name              AS expense_type_name,          et.icon              AS expense_type_icon,            upe.amount,          upe.currency,          upe.expense_date,          upe.status,          upe.description,    upe.created_at,            ISNULL(r.has_receipt, 0) AS has_receipt,            CASE               WHEN upe.days_diff = 0 THEN N'Hoy'              WHEN upe.days_diff = 1 THEN N'Ayer'              WHEN upe.days_diff > 1 AND upe.days_diff <= 7                    THEN N'Hace ' + CAST(upe.days_diff AS NVARCHAR(10)) + N' días'              ELSE                    FORMAT(upe.expense_date, 'dd MMM', 'es-CL')          END AS relative_label,            -- Total de gastos del usuario en este proyecto (mismo valor en todas las filas,          -- para que puedas usar First(colGastos).total_expenses en la cabecera)          SUM(upe.amount) OVER() AS total_expenses      FROM UserProjectExpenses upe      INNER JOIN projects p       ON p.id = upe.project_id      LEFT  JOIN expense_types et ON et.id = upe.expense_type_id      LEFT  JOIN Receipts r       ON r.expense_id = upe.expense_id      ORDER BY upe.expense_date DESC, upe.amount DESC;  END;    
GO  CREATE   PROCEDURE [dbo].[sp_GetProjectNotes]  (      @UserEmail          NVARCHAR(255),      @FromDate           NVARCHAR(20)     = NULL,   -- cambiado a NVARCHAR      @ToDate             NVARCHAR(20)     = NULL,   -- cambiado a NVARCHAR      @ProjectId          UNIQUEIDENTIFIER = NULL,      @EmployeeId         UNIQUEIDENTIFIER = NULL,      @ObservationTypeId  INT              = NULL,      @OnlyImportant      BIT              = NULL,      @OnlyWithPhotos     BIT              = NULL,      @SearchText         NVARCHAR(200)    = NULL  )  AS  BEGIN      SET NOCOUNT ON;        DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        DECLARE @ModuleId INT = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @ModuleId = id          FROM [dbo].[app_modules]          WHERE code      = 'jobreports'            AND is_active = 1;            IF @ModuleId IS NULL              SET @EmptyResult = 1;      END        DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = @ModuleId;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = @ModuleId;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS note_id,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS NVARCHAR(100))    AS project_city,              CAST(NULL AS VARCHAR(50))      AS project_state,              CAST(NULL AS VARCHAR(50))      AS project_company,              CAST(NULL AS VARCHAR(50))      AS project_color,              CAST(NULL AS NVARCHAR(100))    AS project_label,              CAST(NULL AS UNIQUEIDENTIFIER) AS user_id,              CAST(NULL AS NVARCHAR(200))    AS employee_name,              CAST(NULL AS VARCHAR(255))     AS employee_email,              CAST(NULL AS VARCHAR(50))      AS employee_role,              CAST(NULL AS INT)              AS observation_type_id,              CAST(NULL AS NVARCHAR(100))    AS observation_type_name,              CAST(NULL AS VARCHAR(50))      AS observation_type_icon,              CAST(NULL AS VARCHAR(50))      AS observation_type_color,              CAST(NULL AS NVARCHAR(200))    AS title,              CAST(NULL AS NVARCHAR(MAX))    AS content,              CAST(NULL AS BIT)              AS is_important,              CAST(NULL AS BIT)              AS is_visible_to_client,              CAST(NULL AS INT)              AS attachment_count,              CAST(NULL AS VARCHAR(500))     AS first_thumbnail_url,              CAST(NULL AS DATETIME2)        AS created_at,              CAST(NULL AS DATETIME2)        AS updated_at          WHERE 1 = 0;          RETURN;      END         -- Normalizar fechas: "" o NULL → NULL real      DECLARE @FromDateParsed DATE = NULLIF(NULLIF(LTRIM(RTRIM(ISNULL(@FromDate, ''))), ''), '');      DECLARE @ToDatParsed    DATE = NULLIF(NULLIF(LTRIM(RTRIM(ISNULL(@ToDate,   ''))), ''), '');        -- Si ToDate vacío, usar FromDate como límite (solo ese día)      DECLARE @EffectiveToDate DATE = ISNULL(@ToDatParsed, @FromDateParsed);        ;WITH NotesBase AS      (          SELECT              pn.id                  AS note_id,              pn.project_id,              pn.user_id,              pn.observation_type_id,              pn.title,              pn.content,              pn.is_important,              pn.is_visible_to_client,              pn.created_at,              pn.updated_at          FROM [dbo].[project_notes] pn          WHERE              pn.is_active = 1     AND (@FromDateParsed  IS NULL OR CAST(pn.created_at AS DATE) >= @FromDateParsed)     AND (@EffectiveToDate IS NULL OR CAST(pn.created_at AS DATE) <= @EffectiveToDate)              AND (@ProjectId         IS NULL OR pn.project_id = @ProjectId)              AND (@EmployeeId        IS NULL OR pn.user_id = @EmployeeId)              AND (@ObservationTypeId IS NULL OR pn.observation_type_id = @ObservationTypeId)              AND (@OnlyImportant     IS NULL OR @OnlyImportant = 0 OR pn.is_important = 1)              AND (                      @SearchText IS NULL                   OR LTRIM(RTRIM(@SearchText)) = N''                   OR pn.title   LIKE N'%' + @SearchText + N'%'                   OR pn.content LIKE N'%' + @SearchText + N'%'                  )              AND (                      @DataScope = 'all'                   OR (@DataScope = 'own' AND pn.user_id = @CallerId)                   OR (                          @DataScope = 'assigned_projects'                          AND pn.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      ),      -- Contar adjuntos por note      AttachCount AS      (          SELECT              note_id,              COUNT(*) AS attachment_count          FROM [dbo].[note_attachments]          WHERE is_active = 1          GROUP BY note_id      ),      -- Obtener el primer thumbnail por sort_order usando ROW_NUMBER      AttachFirst AS      (          SELECT              note_id,              thumbnail_url,              ROW_NUMBER() OVER (                  PARTITION BY note_id                  ORDER BY sort_order ASC              ) AS rn          FROM [dbo].[note_attachments]          WHERE is_active = 1      )        SELECT          nb.note_id,            p.id                                      AS project_id,          p.code                                    AS project_code,          p.name                                    AS project_name,          p.city                                    AS project_city,          p.state                                   AS project_state,          p.company                                 AS project_company,          p.color                                   AS project_color,    p.code + N' - ' + p.name + N', ' + p.city + N', ' + p.state AS project_label,            u.id                                      AS user_id,          u.first_name + N' ' + u.last_name         AS employee_name,          u.email                                   AS employee_email,          pa.role                                   AS employee_role,            ot.id                                     AS observation_type_id,          ot.name                                   AS observation_type_name,          ot.icon                                   AS observation_type_icon,          ot.color                                  AS observation_type_color,            nb.title,          nb.content,          nb.is_important,          nb.is_visible_to_client,            ISNULL(ac.attachment_count, 0)            AS attachment_count,          af.thumbnail_url                          AS first_thumbnail_url,            nb.created_at,          nb.updated_at        FROM NotesBase nb      INNER JOIN [dbo].[projects] p ON p.id = nb.project_id      INNER JOIN [dbo].[users]    u ON u.id = nb.user_id      LEFT  JOIN [dbo].[observation_types] ot             ON ot.id = nb.observation_type_id      LEFT  JOIN [dbo].[project_assignments] pa             ON pa.project_id = nb.project_id            AND pa.user_id    = nb.user_id            AND pa.is_active  = 1      LEFT  JOIN AttachCount ac ON ac.note_id = nb.note_id      LEFT  JOIN AttachFirst  af ON af.note_id = nb.note_id AND af.rn = 1      WHERE          (@OnlyWithPhotos IS NULL OR @OnlyWithPhotos = 0 OR ISNULL(ac.attachment_count, 0) > 0)      ORDER BY          nb.created_at DESC;    END;  
GO  CREATE   PROCEDURE dbo.sp_GetProjectRefundsDeductionsForUser  (      @ProjectId  UNIQUEIDENTIFIER,      @UserEmail  VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        ---------------------------------------------------------------      -- 1. Resolver user_id por email      ---------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = u.id      FROM dbo.users u      WHERE u.email = @UserEmail        AND (u.is_active = 1 OR u.is_active IS NULL);        IF @UserId IS NULL      BEGIN          -- Si no hay usuario, devolvemos 0 filas (no error duro para Power Apps)          SELECT TOP (0)              rd.*           FROM dbo.refunds_deductions rd;          RETURN;      END;        ---------------------------------------------------------------      -- 2. Devolver todos los RD del usuario en ese proyecto      ---------------------------------------------------------------      SELECT          rd.id,          rd.user_id,          u.email              AS user_email,          u.first_name         AS user_first_name,          u.last_name          AS user_last_name,            rd.project_id,          p.code               AS project_code,          p.name               AS project_name,            rd.type,          rd.description,          rd.amount,          rd.currency,          rd.effective_date,          rd.status,            rd.approved_by,          u2.email             AS approved_by_email,          rd.approved_at,          rd.rejection_reason,            rd.applied_at,          rd.payroll_reference,          rd.notes,          rd.is_active,          rd.created_at,          rd.updated_at,          rd.created_by,          rd.updated_by      FROM dbo.refunds_deductions rd      INNER JOIN dbo.users u          ON u.id = rd.user_id      LEFT JOIN dbo.projects p          ON p.id = rd.project_id      LEFT JOIN dbo.users u2          ON u2.id = rd.approved_by      WHERE          rd.user_id   = @UserId          AND rd.project_id = @ProjectId          AND (rd.is_active = 1 OR rd.is_active IS NULL)      ORDER BY          rd.effective_date DESC,          rd.created_at DESC;  END;  
GO    CREATE PROCEDURE [dbo].[sp_GetProjectsList]  (      @ProjectTypeId INT              = NULL,   -- filtro por tipo (NULL = todos)      @StatusId      INT              = NULL,   -- id de estado (NULL = todos)      @ClientId      UNIQUEIDENTIFIER = NULL,   -- cliente (NULL = todos)      @SearchText    NVARCHAR(200)    = NULL,   -- texto de búsqueda (code / name / client_name)      @Company       NVARCHAR(200)    = NULL,   -- compañía (NULL o '' = todas)      @City          NVARCHAR(100)    = NULL,   -- ciudad (NULL o '' = todas)      @State         NVARCHAR(50)     = NULL    -- estado (NULL o '' = todas)  )  AS  BEGIN      SET NOCOUNT ON;        ;WITH Base AS      (          SELECT              p.id                 AS project_id,              p.code               AS project_code,              p.name               AS project_name,              p.color,              p.description,              p.client_id,              c.name               AS client_name,              p.company,              p.project_type_id,              pt.code              AS project_type_code,              pt.name              AS project_type_name,       p.zipcode    AS zipcode,     p.google_maps_link  AS maps_link,     p.latitude           AS latitude,     p.longitude          AS longitude,                p.status_id,              ps.code              AS status_code,              ps.name              AS status_name,                p.progress_percentage,              p.address,              p.city,                p.start_date,              p.estimated_end_date,                p.budget_amount,              p.state,              p.is_active,              p.created_at,              p.updated_at          FROM dbo.projects p          LEFT JOIN dbo.clients        c  ON c.id  = p.client_id          LEFT JOIN dbo.project_types  pt ON pt.id = p.project_type_id          LEFT JOIN dbo.project_status ps ON ps.id = p.status_id          WHERE              p.is_active = 1              AND (@ProjectTypeId IS NULL OR p.project_type_id = @ProjectTypeId)              AND (@ClientId      IS NULL OR p.client_id      = @ClientId)              AND (@StatusId      IS NULL OR p.status_id      = @StatusId)              -- Filtro por compañía (opcional)              AND (                      @Company IS NULL                   OR LTRIM(RTRIM(@Company)) = N''                   OR p.company = @Company                  )              -- Filtro por ciudad (opcional)              AND (                      @City IS NULL                   OR LTRIM(RTRIM(@City)) = N''                   OR p.city = @City                  )              -- Filtro por estado (opcional)              AND (                      @State IS NULL                   OR LTRIM(RTRIM(@State)) = N''                   OR p.state = @State                  )              -- Búsqueda de texto: SOLO por code / name / client_name              AND (                      @SearchText IS NULL                   OR LTRIM(RTRIM(@SearchText)) = N''                   OR (                          p.name    LIKE N'%' + @SearchText + N'%'                          OR p.code LIKE N'%' + @SearchText + N'%'                          OR c.name LIKE N'%' + @SearchText + N'%'                      )                  )      )      SELECT          project_id,          project_code,          project_name,          color,          description,          client_id,          client_name,          company,          project_type_id,          project_type_code,          project_type_name,            status_id,          status_code,          status_name,    latitude,    longitude,    zipcode,    maps_link,            progress_percentage,          address,          city,          start_date,          estimated_end_date,          budget_amount,          state,          is_active,          created_at,          updated_at      FROM Base      ORDER BY           status_code,          project_name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetProjectsSummaryByRange]  (      @FromDate  DATE,                     -- inclusive      @ToDate    DATE,                     -- inclusive      @Company   NVARCHAR(200) = NULL      -- opcional: filtrar por compañía  )  AS  BEGIN      SET NOCOUNT ON;        IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        ;WITH Base AS      (          SELECT              te.id,              te.user_id,              te.project_id,              te.billable_hours,              te.total_amount,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM dbo.time_entries te          WHERE              te.is_active = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) BETWEEN @FromDate AND @ToDate      )      SELECT          p.id              AS project_id,          p.code            AS project_code,          p.name            AS project_name,          p.city,          p.state,          p.company,          p.color,                              -- color del proyecto            COUNT(DISTINCT b.user_id)              AS total_employees,          ISNULL(SUM(b.billable_hours), 0)       AS total_billable_hours,          ISNULL(SUM(b.total_amount), 0)         AS total_revenue,            CAST(0 AS bit) AS IsExpanded           -- siempre FALSE al cargar      FROM Base b      INNER JOIN dbo.projects p ON p.id = b.project_id      WHERE          @Company IS NULL          OR LTRIM(RTRIM(@Company)) = N''          OR p.company = @Company      GROUP BY          p.id, p.code, p.name, p.city, p.state, p.company, p.color      ORDER BY          p.name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetProjectTypes]  AS  BEGIN      SET NOCOUNT ON;        SELECT          pt.id          AS project_type_id,          pt.code        AS project_type_code,          pt.name        AS project_type_name,          pt.description,          pt.color,          pt.is_active,          pt.created_at,          pt.updated_at      FROM dbo.project_types pt      WHERE pt.is_active = 1      -- solo activos; quita esta línea si quieres TODOS      ORDER BY pt.name;  END;  
GO  CREATE   PROCEDURE dbo.sp_GetRefundDeductionAttachments  (      @RefundDeductionId UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          rda.id,          rda.refund_deduction_id,          rda.file_name,          rda.file_url,          rda.file_size,          rda.file_type,          rda.thumbnail_url,          rda.is_primary,          rda.sort_order,          rda.is_active,          rda.created_at,          rda.uploaded_by,          u.email        AS uploaded_by_email,          u.first_name   AS uploaded_by_first_name,          u.last_name    AS uploaded_by_last_name      FROM dbo.refunds_deductions_attachments rda      LEFT JOIN dbo.users u          ON u.id = rda.uploaded_by      WHERE          rda.refund_deduction_id = @RefundDeductionId          AND (rda.is_active = 1 OR rda.is_active IS NULL)      ORDER BY          rda.sort_order,          rda.created_at;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetTimeEntriesSummary]  (      @FromDate   DATE,      @ToDate     DATE,      @UserEmail  NVARCHAR(255),      @ProjectId  UNIQUEIDENTIFIER = NULL,      @SearchText NVARCHAR(200)    = NULL  )  AS  BEGIN      SET NOCOUNT ON;        IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        -- =============================================      -- 1. Resolver caller      -- =============================================      DECLARE @CallerId     UNIQUEIDENTIFIER;      DECLARE @CallerRoleId INT;      DECLARE @EmptyResult  BIT = 0;        SELECT          @CallerId     = id,          @CallerRoleId = role_id      FROM [dbo].[users]      WHERE email     = @UserEmail        AND is_active = 1;        IF @CallerId IS NULL          SET @EmptyResult = 1;        -- =============================================      -- 2. Verificar user_module_permissions módulo 5      -- =============================================      DECLARE @IsAllowed BIT = 0;        IF @EmptyResult = 0      BEGIN          SELECT @IsAllowed = is_allowed          FROM [dbo].[user_module_permissions]          WHERE user_id   = @CallerId            AND module_id = 5;            IF ISNULL(@IsAllowed, 0) = 0              SET @EmptyResult = 1;      END        -- =============================================      -- 3. Resolver data_scope desde role_default_permissions      -- =============================================      DECLARE @DataScope VARCHAR(30) = NULL;        IF @EmptyResult = 0      BEGIN          SELECT @DataScope = rdp.data_scope          FROM [dbo].[role_default_permissions] rdp          WHERE rdp.role_id   = @CallerRoleId            AND rdp.module_id = 5;            IF @DataScope IS NULL              SET @EmptyResult = 1;      END        -- =============================================      -- 4. Sin permiso → tabla vacía sin error      -- =============================================      IF @EmptyResult = 1      BEGIN          SELECT              CAST(NULL AS DATE)             AS from_date,              CAST(NULL AS DATE)             AS to_date,              CAST(NULL AS UNIQUEIDENTIFIER) AS user_id,              CAST(NULL AS NVARCHAR(100))    AS first_name,              CAST(NULL AS NVARCHAR(100))    AS last_name,              CAST(NULL AS VARCHAR(255))     AS email,              CAST(NULL AS NVARCHAR(200))    AS user_full_name,              CAST(NULL AS VARCHAR(50))      AS role,              CAST(NULL AS INT)              AS total_entries,              CAST(NULL AS DECIMAL(10,2))    AS total_billable_hours,              CAST(NULL AS DECIMAL(15,2))    AS total_amount,              CAST(NULL AS DECIMAL(10,2))    AS other_payments,              CAST(NULL AS DECIMAL(10,2))    AS avg_hourly_rate_weighted,              CAST(NULL AS DECIMAL(10,2))    AS avg_hours_per_entry,              CAST(NULL AS INT)              AS total_break_minutes          WHERE 1 = 0;          RETURN;      END        -- =============================================      -- 5. Query principal con filtro de data_scope      -- =============================================      ;WITH Base AS      (          SELECT              te.id,              te.user_id,              te.project_id,              te.clock_in_time,              te.clock_out_time,              te.break_minutes,              te.billable_hours,              te.hourly_rate,              te.total_amount,              te.status,              u.first_name,              u.last_name,              u.email,              CAST(                  (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM [dbo].[time_entries] te          INNER JOIN [dbo].[users] u ON u.id = te.user_id          WHERE              te.is_active      = 1              AND te.clock_in_time  IS NOT NULL              AND te.clock_out_time IS NOT NULL              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) >= @FromDate              AND CAST(                      (te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                      AS DATE                  ) <= @ToDate              AND (@ProjectId IS NULL OR te.project_id = @ProjectId)              AND (                      @SearchText IS NULL                   OR LTRIM(RTRIM(@SearchText)) = N''                   OR u.first_name + N' ' + u.last_name LIKE N'%' + @SearchText + N'%'                   OR u.email LIKE N'%' + @SearchText + N'%'                  )              -- Filtro data_scope              AND (                      @DataScope = 'all'                   OR (                          @DataScope = 'assigned_projects'                          AND te.project_id IN (                              SELECT pa_pm.project_id                              FROM [dbo].[project_assignments] pa_pm                              WHERE pa_pm.user_id   = @CallerId                                AND pa_pm.is_active = 1                                AND UPPER(LTRIM(RTRIM(pa_pm.role))) = 'PROJECT MANAGER'                          )                      )                  )      ),      BaseWithRole AS      (          SELECT              b.*,              pa.role          FROM Base b          LEFT JOIN [dbo].[project_assignments] pa              ON  pa.project_id = b.project_id              AND pa.user_id    = b.user_id              AND pa.is_active  = 1      ),      RDSummary AS  (      SELECT          rd.user_id,          SUM(              CASE                  WHEN rd.type = 'deduction'            THEN -rd.amount                  WHEN rd.type IN ('refund','addition')  THEN  rd.amount                  ELSE 0              END          ) AS other_payments      FROM [dbo].[refunds_deductions] rd      WHERE          rd.is_active       = 1          AND rd.effective_date >= @FromDate          AND rd.effective_date <= @ToDate          AND LOWER(LTRIM(RTRIM(rd.status))) = 'approved'      GROUP BY rd.user_id  )        SELECT          @FromDate AS from_date,          @ToDate   AS to_date,            bwr.user_id,          bwr.first_name,          bwr.last_name,          bwr.email,          bwr.first_name + N' ' + bwr.last_name        AS user_full_name,            MAX(bwr.role)                                 AS role,            COUNT(DISTINCT bwr.work_date_ny)              AS total_entries,            ISNULL(SUM(bwr.billable_hours), 0)            AS total_billable_hours,          ISNULL(SUM(bwr.total_amount), 0)              AS total_amount,            ISNULL(rd.other_payments, 0)                  AS other_payments,            CASE              WHEN SUM(bwr.billable_hours) IS NULL OR SUM(bwr.billable_hours) = 0                  THEN NULL              ELSE CAST(SUM(bwr.total_amount) / SUM(bwr.billable_hours) AS DECIMAL(10,2))          END                                           AS avg_hourly_rate_weighted,            CASE              WHEN COUNT(DISTINCT bwr.work_date_ny) = 0                  THEN NULL              ELSE CAST(                      SUM(bwr.billable_hours) / COUNT(DISTINCT bwr.work_date_ny)                      AS DECIMAL(10,2)                   )          END                                           AS avg_hours_per_entry,            ISNULL(SUM(ISNULL(bwr.break_minutes, 0)), 0) AS total_break_minutes        FROM BaseWithRole bwr      LEFT JOIN RDSummary rd ON rd.user_id = bwr.user_id      GROUP BY          bwr.user_id,          bwr.first_name,          bwr.last_name,          bwr.email,          rd.other_payments      ORDER BY          bwr.last_name,          bwr.first_name,          bwr.email;    END;  
GO    CREATE PROCEDURE [dbo].[sp_GetTodayLastTimeEntryByEmail]  (      @UserEmail VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS last_entry_id,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS DATETIME2)        AS clock_in_time,              CAST(NULL AS DATETIME2)        AS clock_out_time,              CAST(NULL AS DATETIME2)        AS clock_in_time_ny,              CAST(NULL AS DATETIME2)        AS clock_out_time_ny,              CAST(0 AS BIT)                 AS has_open_entry,              CAST('NONE'     AS VARCHAR(20))AS last_action,              CAST('CHECK_IN' AS VARCHAR(20))AS next_action,              CAST(NULL AS INT)              AS total_minutes,              CAST(NULL AS DECIMAL(10,2))    AS total_hours;          RETURN;      END;        -------------------------------------------------------------------      -- 2. "Hoy" y "Ayer" en zona New York (Eastern)      -------------------------------------------------------------------      DECLARE @NowUtc  DATETIME2 = SYSUTCDATETIME();      DECLARE @NowNy   DATETIME2 = CAST(                             @NowUtc AT TIME ZONE 'UTC'                                      AT TIME ZONE 'Eastern Standard Time'                         AS DATETIME2);        DECLARE @TodayNy DATE = CAST(@NowNy AS DATE);      DECLARE @PrevNy  DATE = DATEADD(DAY, -1, @TodayNy);        -------------------------------------------------------------------      -- 3. Buscar marcaciones de HOY (abierta y última del día)      -------------------------------------------------------------------      DECLARE          @TodayOpenId       UNIQUEIDENTIFIER,          @TodayOpenProjId   UNIQUEIDENTIFIER,          @TodayOpenClockIn  DATETIME2;        ;WITH TodayOpen AS      (          SELECT              te.id,              te.project_id,              te.clock_in_time,              CAST(                  (te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NULL      )      SELECT TOP (1)          @TodayOpenId      = t.id,          @TodayOpenProjId  = t.project_id,          @TodayOpenClockIn = t.clock_in_time      FROM TodayOpen t      WHERE t.work_date_ny = @TodayNy      ORDER BY t.clock_in_time DESC;        DECLARE          @TodayLastId      UNIQUEIDENTIFIER,          @TodayLastProjId  UNIQUEIDENTIFIER,          @TodayLastIn      DATETIME2,          @TodayLastOut     DATETIME2,          @TodayLastEvent   DATETIME2;        ;WITH TodayEvents AS      (          SELECT               te.id,              te.project_id,              te.clock_in_time,              te.clock_out_time,              CAST(                  (te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny,              CASE                   WHEN te.clock_out_time IS NOT NULL THEN te.clock_out_time                   ELSE te.clock_in_time               END AS event_time          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1      )      SELECT TOP (1)          @TodayLastId     = id,          @TodayLastProjId = project_id,          @TodayLastIn     = clock_in_time,          @TodayLastOut    = clock_out_time,          @TodayLastEvent  = event_time      FROM TodayEvents      WHERE work_date_ny = @TodayNy      ORDER BY event_time DESC;        -------------------------------------------------------------------      -- 4. Si hay algo HOY, aplicar prioridad:      --    1) si hay abierta -> usar abierta      --    2) si no hay abierta pero hay cerrada -> usar última cerrada      -------------------------------------------------------------------      IF @TodayOpenId IS NOT NULL      BEGIN          DECLARE @MinToday INT, @HoursToday DECIMAL(10,2);            SET @MinToday   = DATEDIFF(MINUTE, @TodayOpenClockIn, @NowUtc);          SET @HoursToday = CAST(@MinToday / 60.0 AS DECIMAL(10,2));            SELECT               te.id                    AS last_entry_id,              te.project_id            AS project_id,              p.code                   AS project_code,              p.name                   AS project_name,              te.clock_in_time,              te.clock_out_time,              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_in_time_ny,              CAST(                  te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_out_time_ny,              CAST(1 AS BIT)           AS has_open_entry,              CAST('IN' AS VARCHAR(20))       AS last_action,              CAST('CHECK_OUT' AS VARCHAR(20))AS next_action,              @MinToday                AS total_minutes,              @HoursToday              AS total_hours          FROM time_entries te          INNER JOIN projects p ON p.id = te.project_id          WHERE te.id = @TodayOpenId;            RETURN;      END;        IF @TodayLastId IS NOT NULL      BEGIN          -- No hay abierta hoy, pero sí hubo marcación (completa o solo IN)          DECLARE @MinToday2 INT, @HoursToday2 DECIMAL(10,2),                  @LastActionToday VARCHAR(20), @NextActionToday VARCHAR(20);            IF @TodayLastOut IS NOT NULL          BEGIN              -- Última fue salida completa              SET @LastActionToday = 'OUT';              SET @NextActionToday = 'CHECK_IN';              SET @MinToday2   = DATEDIFF(MINUTE, @TodayLastIn, @TodayLastOut);              SET @HoursToday2 = CAST(@MinToday2 / 60.0 AS DECIMAL(10,2));          END          ELSE          BEGIN              -- Última es un IN sin OUT (caso raro porque ya no hay abierta,              -- pero lo manejamos por seguridad)              SET @LastActionToday = 'IN';              SET @NextActionToday = 'CHECK_OUT';              SET @MinToday2   = DATEDIFF(MINUTE, @TodayLastIn, @NowUtc);              SET @HoursToday2 = CAST(@MinToday2 / 60.0 AS DECIMAL(10,2));          END;            SELECT               te.id                    AS last_entry_id,              te.project_id            AS project_id,              p.code                   AS project_code,              p.name                   AS project_name,              te.clock_in_time,              te.clock_out_time,              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_in_time_ny,              CAST(                  te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_out_time_ny,              CAST(0 AS BIT)                 AS has_open_entry,              @LastActionToday               AS last_action,              @NextActionToday               AS next_action,              @MinToday2                     AS total_minutes,              @HoursToday2                   AS total_hours          FROM time_entries te          INNER JOIN projects p ON p.id = te.project_id          WHERE te.id = @TodayLastId;            RETURN;      END;        -------------------------------------------------------------------      -- 5. Si NO hay nada HOY, mirar AYER      -------------------------------------------------------------------      DECLARE          @PrevOpenId      UNIQUEIDENTIFIER,          @PrevOpenProjId  UNIQUEIDENTIFIER,          @PrevOpenIn      DATETIME2;        ;WITH PrevOpen AS      (          SELECT              te.id,              te.project_id,              te.clock_in_time,              CAST(                  (te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NULL      )      SELECT TOP (1)          @PrevOpenId     = t.id,          @PrevOpenProjId = t.project_id,          @PrevOpenIn     = t.clock_in_time      FROM PrevOpen t      WHERE t.work_date_ny = @PrevNy      ORDER BY t.clock_in_time DESC;        DECLARE          @PrevLastId     UNIQUEIDENTIFIER,          @PrevLastProjId UNIQUEIDENTIFIER,          @PrevLastIn     DATETIME2,          @PrevLastOut    DATETIME2,          @PrevLastEvent  DATETIME2;        ;WITH PrevEvents AS      (          SELECT               te.id,              te.project_id,              te.clock_in_time,              te.clock_out_time,              CAST(                  (te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time')                  AS DATE              ) AS work_date_ny,              CASE                   WHEN te.clock_out_time IS NOT NULL THEN te.clock_out_time                   ELSE te.clock_in_time               END AS event_time          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1      )      SELECT TOP (1)          @PrevLastId     = id,          @PrevLastProjId = project_id,          @PrevLastIn     = clock_in_time,          @PrevLastOut    = clock_out_time,          @PrevLastEvent  = event_time      FROM PrevEvents      WHERE work_date_ny = @PrevNy      ORDER BY event_time DESC;        -- 5.1 Prioridad ayer: primero cerrada, luego abierta      IF @PrevLastId IS NOT NULL AND @PrevLastOut IS NOT NULL      BEGIN          -- Ayer tiene marcación completa -> sirve como última acción OUT          DECLARE @MinPrev INT, @HoursPrev DECIMAL(10,2);            SET @MinPrev   = DATEDIFF(MINUTE, @PrevLastIn, @PrevLastOut);          SET @HoursPrev = CAST(@MinPrev / 60.0 AS DECIMAL(10,2));            SELECT               te.id                    AS last_entry_id,              te.project_id            AS project_id,              p.code                   AS project_code,              p.name                   AS project_name,              te.clock_in_time,              te.clock_out_time,              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_in_time_ny,              CAST(                  te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_out_time_ny,              CAST(0 AS BIT)                 AS has_open_entry,              CAST('OUT' AS VARCHAR(20))     AS last_action,              CAST('CHECK_IN' AS VARCHAR(20))AS next_action,              @MinPrev                      AS total_minutes,              @HoursPrev                    AS total_hours          FROM time_entries te          INNER JOIN projects p ON p.id = te.project_id          WHERE te.id = @PrevLastId;            RETURN;      END;        IF @PrevOpenId IS NOT NULL      BEGIN          -- No hay completa ayer, pero sí abierta          DECLARE @MinPrev2 INT, @HoursPrev2 DECIMAL(10,2);            SET @MinPrev2   = DATEDIFF(MINUTE, @PrevOpenIn, @NowUtc);          SET @HoursPrev2 = CAST(@MinPrev2 / 60.0 AS DECIMAL(10,2));            SELECT               te.id                    AS last_entry_id,              te.project_id            AS project_id,              p.code                   AS project_code,              p.name                   AS project_name,              te.clock_in_time,              te.clock_out_time,              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_in_time_ny,              CAST(                  te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_out_time_ny,              CAST(1 AS BIT)                 AS has_open_entry,              CAST('IN' AS VARCHAR(20))      AS last_action,              CAST('CHECK_OUT' AS VARCHAR(20))AS next_action,              @MinPrev2                      AS total_minutes,              @HoursPrev2                    AS total_hours          FROM time_entries te          INNER JOIN projects p ON p.id = te.project_id          WHERE te.id = @PrevOpenId;            RETURN;      END;        -------------------------------------------------------------------      -- 6. Si tampoco hay nada AYER -> sin marcaciones recientes      -------------------------------------------------------------------      SELECT           CAST(NULL AS UNIQUEIDENTIFIER) AS last_entry_id,          CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,          CAST(NULL AS VARCHAR(50))      AS project_code,          CAST(NULL AS NVARCHAR(200))    AS project_name,          CAST(NULL AS DATETIME2)        AS clock_in_time,          CAST(NULL AS DATETIME2)        AS clock_out_time,          CAST(NULL AS DATETIME2)        AS clock_in_time_ny,          CAST(NULL AS DATETIME2)        AS clock_out_time_ny,          CAST(0 AS BIT)                 AS has_open_entry,          CAST('NONE'     AS VARCHAR(20))AS last_action,          CAST('CHECK_IN' AS VARCHAR(20))AS next_action,          CAST(NULL AS INT)              AS total_minutes,          CAST(NULL AS DECIMAL(10,2))    AS total_hours;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetUserModulesByEmail]  (      @UserEmail VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- Usuario no encontrado: resultset vacío          SELECT               CAST(NULL AS INT)          AS module_id,              CAST(NULL AS VARCHAR(50))  AS module_code,              CAST(NULL AS NVARCHAR(100))AS module_name,              CAST(NULL AS NVARCHAR(255))AS module_description,              CAST(NULL AS NVARCHAR(50)) AS nav_section,              CAST(NULL AS VARCHAR(50))  AS icon,              CAST(NULL AS INT)          AS sort_order,              CAST(NULL AS VARCHAR(20))  AS permission_level          WHERE 1 = 0;          RETURN;      END        SELECT          m.id           AS module_id,          m.code         AS module_code,          m.name         AS module_name,          m.description  AS module_description,          m.nav_section,          m.icon,          m.sort_order,          ump.permission_level      FROM user_module_permissions ump      INNER JOIN app_modules m ON m.id = ump.module_id      WHERE           ump.user_id   = @UserId          AND ump.is_allowed = 1          AND m.is_active    = 1      ORDER BY           m.sort_order,          m.name;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_GetWeeklyApprovedRefundsDeductionsByProjectByEmail]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL,   -- compatibilidad (si no se usan From/To)      @FromDate      DATE = NULL,   -- fecha inicial opcional      @ToDate        DATE = NULL    -- fecha final opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;      SELECT @UserId = id      FROM dbo.users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(50))      AS project_color,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(0    AS DECIMAL(15,2))    AS total_refunds_approved,              CAST(0    AS DECIMAL(15,2))    AS total_deductions_approved          WHERE 1 = 0;          RETURN;      END;        -------------------------------------------------------------------      -- 2. Determinar rango de fechas      -------------------------------------------------------------------      DECLARE @RefDate   DATE;      DECLARE @WeekStart DATE;      DECLARE @WeekEnd   DATE;        IF @FromDate IS NOT NULL AND @ToDate IS NOT NULL      BEGIN          -- Rango manual          SET @WeekStart = @FromDate;          SET @WeekEnd   = @ToDate;      END      ELSE      BEGIN          -- Semana de @ReferenceDate u hoy          IF @ReferenceDate IS NULL              SET @RefDate = CAST(GETUTCDATE() AS DATE);          ELSE              SET @RefDate = @ReferenceDate;            SELECT @WeekStart = WeekStart, @WeekEnd = WeekEnd          FROM dbo.fn_GetWeekRange(@RefDate);      END;        -------------------------------------------------------------------      -- 3. Refunds / Deductions APROBADOS por proyecto en el rango      -------------------------------------------------------------------      ;WITH RDWeekApproved AS      (          SELECT              rd.project_id,              SUM(CASE WHEN rd.type = 'refund'    THEN rd.amount ELSE 0 END)    AS total_refunds_approved,              SUM(CASE WHEN rd.type = 'deduction' THEN rd.amount ELSE 0 END)    AS total_deductions_approved          FROM dbo.refunds_deductions rd          WHERE              rd.user_id = @UserId              AND rd.is_active = 1              AND rd.status = 'approved'              AND rd.effective_date BETWEEN @WeekStart AND @WeekEnd          GROUP BY              rd.project_id      )      SELECT          p.id       AS project_id,          p.code     AS project_code,          p.color    AS project_color,          p.name     AS project_name,          rdwa.total_refunds_approved,          rdwa.total_deductions_approved      FROM RDWeekApproved rdwa      INNER JOIN dbo.projects p          ON p.id = rdwa.project_id      ORDER BY          p.name;  END;  
GO  CREATE PROCEDURE [dbo].[sp_GetWeeklyExpensesByProjectByEmail]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL,   -- se mantiene para compatibilidad      @FromDate      DATE = NULL,   -- NUEVO: fecha inicial opcional      @ToDate        DATE = NULL    -- NUEVO: fecha final opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;      SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(50))      AS project_color,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(0    AS DECIMAL(15,2))    AS expenses          WHERE 1 = 0;          RETURN;      END        -------------------------------------------------------------------      -- 2. Determinar rango de fechas      -------------------------------------------------------------------      DECLARE @RefDate   DATE;      DECLARE @WeekStart DATE;      DECLARE @WeekEnd   DATE;        IF @FromDate IS NOT NULL AND @ToDate IS NOT NULL      BEGIN          -- Rango manual          SET @WeekStart = @FromDate;          SET @WeekEnd   = @ToDate;      END      ELSE      BEGIN          -- Comportamiento original (semana de @ReferenceDate u hoy)          IF @ReferenceDate IS NULL              SET @RefDate = CAST(GETUTCDATE() AS DATE);          ELSE              SET @RefDate = @ReferenceDate;            SELECT @WeekStart = WeekStart, @WeekEnd = WeekEnd          FROM dbo.fn_GetWeekRange(@RefDate);      END        -------------------------------------------------------------------      -- 3. Calcular gastos por proyecto en el rango      -------------------------------------------------------------------      ;WITH ExpensesWeek AS      (          SELECT              e.project_id,              SUM(e.amount) AS expenses          FROM expenses e          WHERE              e.user_id = @UserId              AND e.is_active = 1              AND e.status <> 'rejected'              AND e.expense_date BETWEEN @WeekStart AND @WeekEnd          GROUP BY e.project_id      )      SELECT          p.id         AS project_id,          p.code       AS project_code,          p.color      AS project_color,          p.name       AS project_name,          ISNULL(ew.expenses, 0) AS expenses      FROM ExpensesWeek ew      INNER JOIN projects p ON p.id = ew.project_id      ORDER BY expenses DESC, project_name;  END;  
GO  CREATE PROCEDURE [dbo].[sp_GetWeeklyHoursByProjectByEmail]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL,   -- se mantiene para compatibilidad      @FromDate      DATE = NULL,   -- NUEVO: fecha inicial opcional      @ToDate        DATE = NULL    -- NUEVO: fecha final opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;      SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(50))      AS project_color,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(0    AS DECIMAL(10,2))    AS hours,              CAST(0    AS DECIMAL(10,2))    AS hourly_rate_avg,              CAST(0    AS DECIMAL(15,2))    AS amount_by_hours          WHERE 1 = 0;          RETURN;      END        -------------------------------------------------------------------      -- 2. Determinar rango de fechas      -------------------------------------------------------------------      DECLARE @RefDate   DATE;      DECLARE @WeekStart DATE;      DECLARE @WeekEnd   DATE;        IF @FromDate IS NOT NULL AND @ToDate IS NOT NULL      BEGIN          -- Rango manual          SET @WeekStart = @FromDate;          SET @WeekEnd   = @ToDate;      END      ELSE      BEGIN          -- Comportamiento original (semana de @ReferenceDate u hoy)          IF @ReferenceDate IS NULL              SET @RefDate = CAST(GETUTCDATE() AS DATE);          ELSE              SET @RefDate = @ReferenceDate;            SELECT @WeekStart = WeekStart, @WeekEnd = WeekEnd          FROM dbo.fn_GetWeekRange(@RefDate);      END        -------------------------------------------------------------------      -- 3. Calcular horas y montos por proyecto      -------------------------------------------------------------------      ;WITH TimeDetail AS      (          SELECT              te.project_id,              SUM(ISNULL(te.billable_hours, te.total_hours))                             AS sum_hours,              SUM(ISNULL(te.billable_hours, te.total_hours) * ISNULL(te.hourly_rate,0)) AS sum_amount          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND CAST(te.clock_in_time AS DATE) BETWEEN @WeekStart AND @WeekEnd          GROUP BY te.project_id      )      SELECT          p.id                AS project_id,          p.code              AS project_code,          p.color             AS project_color,          p.name              AS project_name,          ISNULL(td.sum_hours, 0)                             AS hours,          CASE              WHEN td.sum_hours IS NULL OR td.sum_hours = 0                   THEN 0              ELSE CAST(td.sum_amount / td.sum_hours AS DECIMAL(10,2))          END                                                AS hourly_rate_avg,          ISNULL(td.sum_amount, 0)                           AS amount_by_hours      FROM TimeDetail td      INNER JOIN projects p ON p.id = td.project_id      ORDER BY amount_by_hours DESC, project_name;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_GetWeeklySummaryByEmail]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL  -- si es NULL, usa la fecha de hoy (UTC)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Usuario por email      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- Usuario no encontrado: devolvemos tres resultsets vacíos          -- Resultset 1: resumen          SELECT               CAST(NULL AS DATE)          AS week_start,              CAST(NULL AS DATE)          AS week_end,              CAST(0    AS DECIMAL(10,2)) AS total_hours,              CAST(0    AS DECIMAL(15,2)) AS total_by_hours,              CAST(0    AS DECIMAL(15,2)) AS total_expenses,              CAST(0    AS INT)           AS projects_count,              CAST(0    AS DECIMAL(15,2)) AS grand_total;            -- Resultset 2: desglose horas por proyecto          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(0    AS DECIMAL(10,2))    AS hours,              CAST(0    AS DECIMAL(10,2))    AS hourly_rate_avg,              CAST(0    AS DECIMAL(15,2))    AS amount_by_hours          WHERE 1 = 0;            -- Resultset 3: gastos por proyecto          SELECT               CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(0    AS DECIMAL(15,2))    AS expenses          WHERE 1 = 0;            RETURN;      END        -------------------------------------------------------------------      -- 2. Calcular semana (lunes-domingo) a partir de ReferenceDate / hoy      -------------------------------------------------------------------      DECLARE           @RefDate      DATE,          @WeekStart    DATE,          @WeekEnd      DATE,          @PrevDateFirst INT = @@DATEFIRST;        IF @ReferenceDate IS NULL          SET @RefDate = CAST(GETUTCDATE() AS DATE);      ELSE          SET @RefDate = @ReferenceDate;        -- Tomamos lunes como primer día de la semana      SET DATEFIRST 1; -- lunes        SET @WeekStart = DATEADD(DAY, -(DATEPART(WEEKDAY, @RefDate) - 1), @RefDate);      SET @WeekEnd   = DATEADD(DAY, 6, @WeekStart);        -- Restaurar configuración anterior      SET DATEFIRST @PrevDateFirst;        -------------------------------------------------------------------      -- 3. CTE con horas por proyecto en la semana para este usuario      -------------------------------------------------------------------      ;WITH TimeWeek AS      (          SELECT              te.project_id,              SUM(                  ISNULL(te.billable_hours, te.total_hours)              ) AS hours,              SUM(                  ISNULL(te.billable_hours, te.total_hours)                   * ISNULL(te.hourly_rate, 0)              ) AS amount_by_hours,              NULL AS dummy          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND CAST(te.clock_in_time AS DATE) BETWEEN @WeekStart AND @WeekEnd          GROUP BY te.project_id      ),      ExpensesWeek AS      (          SELECT              e.project_id,              SUM(e.amount) AS expenses          FROM expenses e          WHERE              e.user_id = @UserId              AND e.is_active = 1              AND e.status <> 'rejected' -- opcional, excluimos rechazados              AND e.expense_date BETWEEN @WeekStart AND @WeekEnd          GROUP BY e.project_id      ),      TimeDetail AS      (          -- Para calcular tarifa promedio por proyecto          SELECT              te.project_id,              SUM(ISNULL(te.billable_hours, te.total_hours))           AS sum_hours,              SUM(ISNULL(te.billable_hours, te.total_hours) * ISNULL(te.hourly_rate,0)) AS sum_amount          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND CAST(te.clock_in_time AS DATE) BETWEEN @WeekStart AND @WeekEnd          GROUP BY te.project_id      )        -------------------------------------------------------------------      -- 4. Resultset 1: Resumen semanal global      -------------------------------------------------------------------      SELECT          @WeekStart AS week_start,          @WeekEnd   AS week_end,          ISNULL(SUM(tw.hours), 0)                AS total_hours,          ISNULL(SUM(tw.amount_by_hours), 0)      AS total_by_hours,          ISNULL(SUM(ew.expenses), 0)             AS total_expenses,          COUNT(DISTINCT tw.project_id)           AS projects_count,          ISNULL(SUM(tw.amount_by_hours), 0)           + ISNULL(SUM(ew.expenses), 0)           AS grand_total      FROM TimeWeek tw      FULL OUTER JOIN ExpensesWeek ew          ON ew.project_id = tw.project_id;        -------------------------------------------------------------------      -- 5. Resultset 2: Desglose por proyecto (horas)      -------------------------------------------------------------------      SELECT          p.id                AS project_id,          p.code              AS project_code,          p.name              AS project_name,          ISNULL(td.sum_hours, 0)                             AS hours,          CASE               WHEN td.sum_hours IS NULL OR td.sum_hours = 0                   THEN 0              ELSE CAST(td.sum_amount / td.sum_hours AS DECIMAL(10,2))          END                                                AS hourly_rate_avg,          ISNULL(td.sum_amount, 0)                           AS amount_by_hours      FROM TimeDetail td      INNER JOIN projects p ON p.id = td.project_id      ORDER BY amount_by_hours DESC, project_name;        -------------------------------------------------------------------      -- 6. Resultset 3: Gastos por proyecto      -------------------------------------------------------------------      SELECT          p.id         AS project_id,          p.code       AS project_code,          p.name       AS project_name,          ISNULL(ew.expenses, 0) AS expenses      FROM ExpensesWeek ew      INNER JOIN projects p ON p.id = ew.project_id      ORDER BY expenses DESC, project_name;    END;  
GO    CREATE PROCEDURE [dbo].[sp_GetWeeklySummaryHeaderByEmail]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL,   -- compatibilidad      @FromDate      DATE = NULL,   -- fecha inicial opcional      @ToDate        DATE = NULL    -- fecha final opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;      SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          SELECT               CAST(NULL AS DATE)          AS week_start,              CAST(NULL AS DATE)          AS week_end,              CAST(0    AS DECIMAL(10,2)) AS total_hours,     CAST('0h 0m' AS NVARCHAR(10)) AS total_hours_label,              CAST(0    AS DECIMAL(15,2)) AS total_by_hours,              CAST(0    AS DECIMAL(15,2)) AS total_expenses,              CAST(0    AS INT)           AS projects_count,              CAST(0    AS DECIMAL(15,2)) AS grand_total,              CAST(0    AS DECIMAL(15,2)) AS total_refunds,              CAST(0    AS DECIMAL(15,2)) AS total_deductions;          RETURN;      END;        -------------------------------------------------------------------      -- 2. Determinar rango de fechas      -------------------------------------------------------------------      DECLARE @RefDate   DATE;      DECLARE @WeekStart DATE;      DECLARE @WeekEnd   DATE;        IF @FromDate IS NOT NULL AND @ToDate IS NOT NULL      BEGIN          -- Rango manual          SET @WeekStart = @FromDate;          SET @WeekEnd   = @ToDate;      END      ELSE      BEGIN          -- Comportamiento original          IF @ReferenceDate IS NULL              SET @RefDate = CAST(GETUTCDATE() AS DATE);          ELSE              SET @RefDate = @ReferenceDate;            SELECT @WeekStart = WeekStart, @WeekEnd = WeekEnd          FROM dbo.fn_GetWeekRange(@RefDate);      END;        -------------------------------------------------------------------      -- 3. Calcular totales de refunds / deductions en variables      -------------------------------------------------------------------      DECLARE           @TotalRefunds    DECIMAL(15,2) = 0,          @TotalDeductions DECIMAL(15,2) = 0;        SELECT          @TotalRefunds = ISNULL(SUM(CASE WHEN rd.type = 'refund'    THEN rd.amount ELSE 0 END), 0),          @TotalDeductions = ISNULL(SUM(CASE WHEN rd.type = 'deduction' THEN rd.amount ELSE 0 END), 0)      FROM refunds_deductions rd      WHERE          rd.user_id = @UserId          AND rd.is_active = 1          AND rd.status = 'approved'          AND rd.effective_date BETWEEN @WeekStart AND @WeekEnd;        -------------------------------------------------------------------      -- 4. CTE para horas / gastos      -------------------------------------------------------------------      ;WITH TimeWeek AS      (          SELECT              te.project_id,              SUM(ISNULL(te.billable_hours, te.total_hours)) AS hours,              SUM(ISNULL(te.billable_hours, te.total_hours) * ISNULL(te.hourly_rate, 0)) AS amount_by_hours          FROM time_entries te          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND CAST(te.clock_in_time AS DATE) BETWEEN @WeekStart AND @WeekEnd          GROUP BY te.project_id      ),      ExpensesWeek AS      (          SELECT              e.project_id,              SUM(e.amount) AS expenses          FROM expenses e          WHERE              e.user_id = @UserId              AND e.is_active = 1              AND e.status <> 'rejected'              AND e.expense_date BETWEEN @WeekStart AND @WeekEnd          GROUP BY e.project_id      )      -------------------------------------------------------------------      -- 5. SELECT final      -------------------------------------------------------------------      -- Usamos una subconsulta para calcular primero el total de horas      -- y luego formatear el texto HH:MM correctamente.      SELECT          @WeekStart AS week_start,          @WeekEnd   AS week_end,            CAST(ISNULL(SUM(tw.hours), 0) AS DECIMAL(10,2)) AS total_hours,            -- Formato HH:MM          -- 1) Pasamos horas a minutos (redondeadas a entero)          -- 2) Sacamos horas y minutos con división / módulo          CONCAT(              CAST( CAST(ROUND(ISNULL(SUM(tw.hours),0) * 60, 0) AS INT) / 60 AS VARCHAR(10)),              'h ',              CAST( CAST(ROUND(ISNULL(SUM(tw.hours),0) * 60, 0) AS INT) % 60 AS VARCHAR(10)),              'm'          ) AS total_hours_label,            ISNULL(SUM(tw.amount_by_hours), 0) AS total_by_hours,          ISNULL(SUM(ew.expenses), 0)        AS total_expenses,          COUNT(DISTINCT COALESCE(tw.project_id, ew.project_id)) AS projects_count,            @TotalRefunds           + ISNULL(SUM(tw.amount_by_hours), 0)          - @TotalDeductions                AS grand_total,            @TotalRefunds                      AS total_refunds,          @TotalDeductions                   AS total_deductions      FROM TimeWeek tw      FULL OUTER JOIN ExpensesWeek ew          ON ew.project_id = tw.project_id;  END;  
GO    CREATE   PROCEDURE dbo.sp_OtherPaymentsAttachments_GetById  (      @OtherPaymentsId UNIQUEIDENTIFIER  )  AS  BEGIN      SET NOCOUNT ON;        SELECT          rda.id,          rda.refund_deduction_id,          rda.file_name,          rda.file_url,          rda.file_size,          rda.file_type,          rda.thumbnail_url,          rda.is_primary,          rda.sort_order,          rda.is_active,          rda.created_at,          rda.uploaded_by,          u.first_name + N' ' + u.last_name AS uploaded_by_name,          u.email                            AS uploaded_by_email      FROM dbo.refunds_deductions_attachments rda      LEFT JOIN dbo.users u          ON u.id = rda.uploaded_by      WHERE          rda.refund_deduction_id = @OtherPaymentsId          AND (rda.is_active = 1 OR rda.is_active IS NULL)      ORDER BY          ISNULL(rda.sort_order, 0),          rda.created_at;  END;  
GO    CREATE   PROCEDURE dbo.sp_ProjectAssignment_Deactivate  (      @AssignmentId UNIQUEIDENTIFIER,   -- id de dbo.project_assignments      @UpdatedByEmail VARCHAR(255) = NULL  -- opcional, para auditoría  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Resolver updated_by (opcional)      -------------------------------------------------------------------      DECLARE @UpdatedBy UNIQUEIDENTIFIER = NULL;        IF @UpdatedByEmail IS NOT NULL AND LTRIM(RTRIM(@UpdatedByEmail)) <> ''      BEGIN          SELECT @UpdatedBy = u.id          FROM dbo.users u          WHERE u.email = @UpdatedByEmail            AND (u.is_active = 1 OR u.is_active IS NULL);      END;        -------------------------------------------------------------------      -- 2. Desactivar assignment      -------------------------------------------------------------------      UPDATE pa      SET           pa.is_active = 0,          pa.updated_at = SYSDATETIME(),          pa.updated_by = ISNULL(@UpdatedBy, pa.updated_by)      FROM dbo.project_assignments pa      WHERE pa.id = @AssignmentId;  END;  
GO    CREATE PROCEDURE [dbo].[sp_ProjectAssignment_Update]  (      @ProjectId   UNIQUEIDENTIFIER,      @Email       VARCHAR(255),      @HourlyRate  DECIMAL(10,2),      @Role        VARCHAR(50),      @UpdatedBy   UNIQUEIDENTIFIER = NULL  )  AS  BEGIN      SET NOCOUNT ON;        DECLARE @UserId UNIQUEIDENTIFIER;        -- Buscar el user_id por email      SELECT @UserId = id      FROM dbo.users      WHERE email = @Email        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('User with email %s not found or inactive.', 16, 1, @Email);          RETURN;      END        UPDATE dbo.project_assignments      SET          hourly_rate = @HourlyRate,          role        = @Role,          updated_at  = SYSUTCDATETIME(),          updated_by  = @UpdatedBy      WHERE project_id = @ProjectId        AND user_id    = @UserId        AND is_active  = 1;        -- Devuelve el registro actualizado      SELECT          pa.id,          pa.project_id,          pa.user_id,          u.email,          pa.role,          pa.hourly_rate,          pa.updated_at,          pa.updated_by      FROM dbo.project_assignments pa      INNER JOIN dbo.users u ON u.id = pa.user_id      WHERE pa.project_id = @ProjectId        AND pa.user_id    = @UserId;  END;
GO    CREATE   PROCEDURE dbo.sp_ProjectNote_Update  (      @NoteId            UNIQUEIDENTIFIER,   -- id de project_notes a editar      @ProjectId         UNIQUEIDENTIFIER,   -- por si cambias de proyecto (opcional)      @UserEmail         VARCHAR(255),       -- usuario que está editando (updated_by)      @ObservationTypeId INT,               -- observation_type_id      @Title             NVARCHAR(200) = NULL,      @Content           NVARCHAR(MAX),      @IsImportant       BIT        = NULL,      @IsVisibleToClient BIT        = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Resolver usuario que edita      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = u.id      FROM dbo.users u      WHERE u.email = @UserEmail        AND (u.is_active = 1 OR u.is_active IS NULL);        IF @UserId IS NULL      BEGIN          RAISERROR('No se encontró un usuario activo con el correo especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Verificar que la nota exista y esté activa (opcional)      -------------------------------------------------------------------      IF NOT EXISTS (          SELECT 1          FROM dbo.project_notes pn          WHERE pn.id = @NoteId            AND (pn.is_active = 1 OR pn.is_active IS NULL)      )      BEGIN          RAISERROR('No se encontró una project_note activa con el Id especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Actualizar la nota      -------------------------------------------------------------------      UPDATE dbo.project_notes      SET          project_id         = @ProjectId,          user_id            = @UserId,           -- quien registra la edición (puedes quitarlo si no quieres cambiarlo)          observation_type_id = @ObservationTypeId,          title              = @Title,          content            = @Content,          is_important       = @IsImportant,          is_visible_to_client = @IsVisibleToClient,          updated_at         = SYSDATETIME(),          updated_by         = @UserId      WHERE id = @NoteId;  END;  
GO    CREATE PROCEDURE dbo.sp_Refund_InactiveFromUser  (      @id UNIQUEIDENTIFIER,      @user_email VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        DECLARE @updated_by UNIQUEIDENTIFIER;        -- Obtener el id del usuario según su email      SELECT @updated_by = id      FROM dbo.users      WHERE email = @user_email;        -- Validar que el usuario exista      IF @updated_by IS NULL      BEGIN          RAISERROR('User with the provided email was not found.',16,1);          RETURN;      END        -- Inactivar el registro      UPDATE dbo.refunds_deductions      SET           is_active = 0,          updated_at = GETDATE(),          updated_by = @updated_by      WHERE id = @id        AND is_active = 1;    END  
GO  CREATE   PROCEDURE [dbo].[sp_RefundDeduction_Upsert]  (      @RDId             UNIQUEIDENTIFIER = NULL,    -- NULL => create, NOT NULL => update        @UserEmail        VARCHAR(255),              -- empleado al que aplica (user_id)      @ProjectId        UNIQUEIDENTIFIER = NULL,   -- opcional, si aplica a un proyecto        @Type             VARCHAR(20),               -- 'refund' o 'deduction'      @Description      NVARCHAR(500),      @Amount           DECIMAL(10,2),      @Currency         VARCHAR(3),      @EffectiveDate    DATE,        @Status           VARCHAR(50),               -- 'pending','approved','rejected', etc.        @Notes            NVARCHAR(MAX) = NULL,        -- Quien está ejecutando la acción (puede ser el mismo empleado u otro usuario/aprobador)      @ActorEmail       VARCHAR(255),              -- se usará para created_by / updated_by        -- SALIDAS      @OutRDId          UNIQUEIDENTIFIER OUTPUT,      @Success          BIT OUTPUT,      @Message          NVARCHAR(400) OUTPUT  )  AS  BEGIN      SET NOCOUNT ON;        BEGIN TRY          ---------------------------------------------------------------          -- 1. Resolver user_id (empleado) por @UserEmail          ---------------------------------------------------------------          DECLARE @UserId UNIQUEIDENTIFIER;            SELECT @UserId = u.id          FROM dbo.users u          WHERE u.email = @UserEmail            AND (u.is_active = 1 OR u.is_active IS NULL);            IF @UserId IS NULL          BEGIN              SET @Success = 0;              SET @Message = N'No se encontró un usuario activo con el correo especificado (UserEmail).';              SET @OutRDId = NULL;              RETURN;          END;            ---------------------------------------------------------------          -- 2. Resolver Actor (created_by / updated_by) por @ActorEmail          ---------------------------------------------------------------          DECLARE @ActorId UNIQUEIDENTIFIER;            SELECT @ActorId = u.id          FROM dbo.users u          WHERE u.email = @ActorEmail            AND (u.is_active = 1 OR u.is_active IS NULL);            IF @ActorId IS NULL          BEGIN              SET @Success = 0;              SET @Message = N'No se encontró un usuario activo con el correo especificado (ActorEmail).';              SET @OutRDId = NULL;              RETURN;          END;            ---------------------------------------------------------------          -- 3. Validaciones básicas          ---------------------------------------------------------------          IF @Type NOT IN ('refund', 'deduction')          BEGIN              SET @Success = 0;              SET @Message = N'El tipo debe ser "refund" o "deduction".';              SET @OutRDId = NULL;              RETURN;          END;            IF @Amount <= 0          BEGIN              SET @Success = 0;              SET @Message = N'El monto debe ser mayor que cero.';              SET @OutRDId = NULL;              RETURN;          END;            ---------------------------------------------------------------          -- 4. Lógica de CREATE vs UPDATE          ---------------------------------------------------------------          IF @RDId IS NULL          BEGIN              -----------------------------------------------------------              -- CREATE              -----------------------------------------------------------              DECLARE @NewId UNIQUEIDENTIFIER = NEWID();                INSERT INTO dbo.refunds_deductions (                  id,                  user_id,                  project_id,                  type,                  description,                  amount,                  currency,                  effective_date,                  status,                  approved_by,                  approved_at,                  rejection_reason,                  applied_at,                  payroll_reference,                  notes,                  is_active,                  created_at,                  updated_at,                  created_by,                  updated_by              )              VALUES (                  @NewId,                  @UserId,                  @ProjectId,                  @Type,                  @Description,                  @Amount,                  @Currency,                  @EffectiveDate,                  @Status,                  NULL,           -- approved_by                  NULL,           -- approved_at                  NULL,           -- rejection_reason                  NULL,           -- applied_at                  NULL,           -- payroll_reference                  @Notes,                  1,              -- is_active                  SYSDATETIME(),  -- created_at                  SYSDATETIME(),  -- updated_at                  @ActorId,       -- created_by                  @ActorId        -- updated_by              );                SET @OutRDId = @NewId;              SET @Success = 1;              SET @Message = N'Refund/Deduction creado correctamente.';          END          ELSE          BEGIN              -----------------------------------------------------------              -- UPDATE              -----------------------------------------------------------              IF NOT EXISTS (                  SELECT 1                  FROM dbo.refunds_deductions rd                  WHERE rd.id = @RDId                    AND (rd.is_active = 1 OR rd.is_active IS NULL)              )              BEGIN                  SET @Success = 0;                  SET @Message = N'No se encontró un Refund/Deduction activo con el Id especificado.';                  SET @OutRDId = NULL;                  RETURN;              END;                UPDATE dbo.refunds_deductions              SET                  user_id        = @UserId,                  project_id     = @ProjectId,                  description    = @Description,                  amount         = @Amount,                  currency       = @Currency,                  status         = @Status,                  notes          = @Notes,                  updated_at     = SYSDATETIME(),                  updated_by     = @ActorId              WHERE id = @RDId;                SET @OutRDId = @RDId;              SET @Success = 1;              SET @Message = N'Refund/Deduction actualizado correctamente.';          END;      END TRY      BEGIN CATCH          SET @Success = 0;          SET @OutRDId = NULL;          SET @Message = ERROR_MESSAGE();      END CATCH;  END;  
GO  CREATE   PROCEDURE dbo.sp_RefundDeductionAttachment_Add  (      @RefundDeductionId UNIQUEIDENTIFIER,   -- RDId que ya tienes      @FileName          NVARCHAR(255),      @FileUrl           VARCHAR(500),      @SortOrder         INT          = NULL,      @UploadedByEmail   VARCHAR(255),       -- email desde PowerApps        @OutAttachmentId   UNIQUEIDENTIFIER OUTPUT,      @Success           BIT            OUTPUT,      @Message           NVARCHAR(400)  OUTPUT  )  AS  BEGIN      SET NOCOUNT ON;        BEGIN TRY          -----------------------------------------------------------          -- 1. Resolver uploaded_by          -----------------------------------------------------------          DECLARE @UploadedBy UNIQUEIDENTIFIER;            SELECT @UploadedBy = u.id          FROM dbo.users u          WHERE u.email = @UploadedByEmail            AND (u.is_active = 1 OR u.is_active IS NULL);            IF @UploadedBy IS NULL          BEGIN              SET @Success = 0;              SET @Message = N'No se encontró un usuario activo con el correo especificado (UploadedByEmail).';              SET @OutAttachmentId = NULL;              RETURN;          END;            -----------------------------------------------------------          -- 2. Verificar que el Refund/Deduction exista          -----------------------------------------------------------          IF NOT EXISTS (              SELECT 1              FROM dbo.refunds_deductions rd              WHERE rd.id = @RefundDeductionId                AND (rd.is_active = 1 OR rd.is_active IS NULL)          )          BEGIN              SET @Success = 0;              SET @Message = N'No se encontró un Refund/Deduction activo con el Id especificado.';              SET @OutAttachmentId = NULL;              RETURN;          END;            -----------------------------------------------------------          -- 3. Insertar attachment          -----------------------------------------------------------          DECLARE @NewId UNIQUEIDENTIFIER = NEWID();            INSERT INTO dbo.refunds_deductions_attachments (              id,              refund_deduction_id,              file_name,              file_url,              file_size,              file_type,              thumbnail_url,              is_primary,              sort_order,              is_active,              created_at,              uploaded_by          )          VALUES (              @NewId,              @RefundDeductionId,              @FileName,              @FileUrl,              NULL,           -- file_size (si luego lo quieres, lo agregas)              NULL,           -- file_type              NULL,           -- thumbnail_url              NULL,           -- is_primary              @SortOrder,              1,              -- is_active              SYSDATETIME(),              @UploadedBy          );            SET @OutAttachmentId = @NewId;          SET @Success = 1;          SET @Message = N'Attachment creado correctamente.';      END TRY      BEGIN CATCH          SET @Success = 0;          SET @OutAttachmentId = NULL;          SET @Message = ERROR_MESSAGE();      END CATCH;  END;  
GO  CREATE   PROCEDURE dbo.sp_RefundDeductionAttachments_DeactivateByIdsCsv  (      @IdsCsv VARCHAR(MAX)  -- lista de GUIDs separados por comas  )  AS  BEGIN      SET NOCOUNT ON;        ;WITH ParsedIds AS      (          SELECT TRY_CAST(value AS UNIQUEIDENTIFIER) AS id          FROM STRING_SPLIT(@IdsCsv, ',')      )      UPDATE rda      SET rda.is_active = 0      FROM dbo.refunds_deductions_attachments rda      INNER JOIN ParsedIds p          ON rda.id = p.id      WHERE p.id IS NOT NULL;  END;  
GO    CREATE   PROCEDURE dbo.sp_RefundsDeductions_Create  (      @ProjectId      UNIQUEIDENTIFIER,      @UserId         UNIQUEIDENTIFIER,      @Type           VARCHAR(20),        -- 'refund' | 'addition' | 'deduction'      @Description    NVARCHAR(500) = NULL,      @Amount         DECIMAL(10,2),      @Currency       VARCHAR(3)   = 'USD',      @EffectiveDate  DATE,      @Status         VARCHAR(50),        -- 'pending' | 'approved' | 'rejected'...      @UserEmail      VARCHAR(255)        -- email del usuario logueado (approved_by + created_by)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @ProjectId IS NULL      BEGIN          RAISERROR('ProjectId es obligatorio.', 16, 1);          RETURN;      END;        IF @UserId IS NULL      BEGIN          RAISERROR('UserId es obligatorio.', 16, 1);          RETURN;      END;        IF @Type IS NULL OR LTRIM(RTRIM(@Type)) = ''      BEGIN          RAISERROR('Type es obligatorio.', 16, 1);          RETURN;      END;        IF @Amount IS NULL      BEGIN          RAISERROR('Amount es obligatorio.', 16, 1);          RETURN;      END;        IF @EffectiveDate IS NULL      BEGIN          RAISERROR('EffectiveDate es obligatorio.', 16, 1);          RETURN;      END;        IF @Status IS NULL OR LTRIM(RTRIM(@Status)) = ''      BEGIN          RAISERROR('Status es obligatorio.', 16, 1);          RETURN;      END;        IF @UserEmail IS NULL OR LTRIM(RTRIM(@UserEmail)) = ''      BEGIN          RAISERROR('UserEmail es obligatorio.', 16, 1);          RETURN;      END;        -- Validar proyecto      IF NOT EXISTS (SELECT 1 FROM dbo.projects WHERE id = @ProjectId AND is_active = 1)      BEGIN          RAISERROR('Proyecto no encontrado o inactivo.', 16, 1);          RETURN;      END;        -- Validar usuario destino      IF NOT EXISTS (SELECT 1 FROM dbo.users WHERE id = @UserId AND is_active = 1)      BEGIN          RAISERROR('Usuario asociado al refund/deduction no encontrado o inactivo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Resolver usuario que crea / aprueba (por email)      -------------------------------------------------------------------      DECLARE @ActorUserId UNIQUEIDENTIFIER;        SELECT @ActorUserId = id      FROM dbo.users      WHERE email = @UserEmail        AND is_active = 1;        IF @ActorUserId IS NULL      BEGIN          RAISERROR('Usuario (UserEmail) no encontrado o inactivo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Insertar refund/deduction      -------------------------------------------------------------------      DECLARE @NowUtc DATETIME2 = SYSUTCDATETIME();      DECLARE @NewId  UNIQUEIDENTIFIER = NEWID();        INSERT INTO dbo.refunds_deductions      (          id,          user_id,          project_id,          type,          description,          amount,          currency,          effective_date,          status,          approved_by,          approved_at,          rejection_reason,          applied_at,          payroll_reference,          notes,          is_active,          created_at,          updated_at,          created_by,          updated_by      )      VALUES      (          @NewId,          @UserId,          @ProjectId,          @Type,          @Description,          @Amount,          @Currency,          @EffectiveDate,          @Status,          -- approved_by y approved_at solo si el status es 'approved'          CASE WHEN LOWER(@Status) = 'approved' THEN @ActorUserId ELSE NULL END,          CASE WHEN LOWER(@Status) = 'approved' THEN @NowUtc      ELSE NULL END,          NULL,           -- rejection_reason          NULL,           -- applied_at          NULL,           -- payroll_reference          NULL,           -- notes          1,              -- is_active          @NowUtc,        -- created_at          NULL,           -- updated_at          @ActorUserId,   -- created_by          NULL            -- updated_by (todavía no hay update)      );        -------------------------------------------------------------------      -- 4. Devolver registro creado con info de usuario y proyecto      -------------------------------------------------------------------      SELECT          rd.id                AS refund_deduction_id,          rd.user_id,          u.first_name + N' ' + u.last_name AS user_full_name,          u.email                            AS user_email,            rd.project_id,          p.name                             AS project_name,          p.code                             AS project_code,            rd.type,          rd.description,          rd.amount,          rd.currency,          rd.effective_date,          rd.status,            rd.approved_by,          au.first_name + N' ' + au.last_name AS approved_by_name,          rd.approved_at,            rd.rejection_reason,          rd.applied_at,          rd.payroll_reference,          rd.notes,            rd.is_active,          rd.created_at,          rd.updated_at,          rd.created_by,          rd.updated_by      FROM dbo.refunds_deductions rd      INNER JOIN dbo.users    u  ON u.id  = rd.user_id      INNER JOIN dbo.projects p  ON p.id  = rd.project_id      LEFT  JOIN dbo.users    au ON au.id = rd.approved_by      WHERE rd.id = @NewId;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_RefundsDeductions_GetList]  (      @UserNameFilter NVARCHAR(200) = NULL,        -- texto libre: nombre/apellido/usuario      @ProjectId      UNIQUEIDENTIFIER = NULL,     -- filtrar por proyecto (opcional)      @Type           VARCHAR(20)      = NULL,     -- 'refund', 'addition', 'deduction', etc.      @Status         VARCHAR(50)      = NULL,     -- 'pending', 'approved', etc.      @FromDate       DATE             = NULL,     -- fecha efectiva DESDE (inclusive)      @ToDate        DATE             = NULL      -- fecha efectiva HASTA (inclusive)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. CTE de conteo de adjuntos activos por refund_deduction      -------------------------------------------------------------------      ;WITH AttachCounts AS      (          SELECT              rda.refund_deduction_id,              COUNT(*) AS attachment_count          FROM dbo.refunds_deductions_attachments rda          WHERE               (rda.is_active = 1 OR rda.is_active IS NULL)          GROUP BY              rda.refund_deduction_id      )      -------------------------------------------------------------------      -- 2. Consulta principal      -------------------------------------------------------------------      SELECT          rd.id,          rd.user_id,          u.first_name + N' ' + u.last_name AS user_full_name,          u.email                            AS user_email,            rd.project_id,          p.name                             AS project_name,          p.code                             AS project_code,    p.color          AS project_color,          p.state                             AS project_state,    p.city          AS project_city,            rd.type,                -- refund / addition / deduction          rd.description,          rd.amount,          rd.currency,          rd.effective_date,          rd.status,            rd.approved_by,          au.first_name + N' ' + au.last_name AS approved_by_name,          rd.approved_at,            rd.rejection_reason,          rd.applied_at,          rd.payroll_reference,          rd.notes,            rd.is_active,          rd.created_at,          rd.updated_at,          rd.created_by,          rd.updated_by,            ISNULL(ac.attachment_count, 0) AS attachment_count      FROM dbo.refunds_deductions rd      INNER JOIN dbo.users    u  ON u.id  = rd.user_id      INNER JOIN dbo.projects p  ON p.id  = rd.project_id      LEFT  JOIN dbo.users    au ON au.id = rd.approved_by      LEFT  JOIN AttachCounts ac ON ac.refund_deduction_id = rd.id      WHERE          -- Solo registros activos (ajústalo si necesitas ver inactivos)          (rd.is_active = 1 OR rd.is_active IS NULL)            -- Filtro por texto de usuario (nombre, apellido, email, username, etc.)          AND (                  @UserNameFilter IS NULL               OR @UserNameFilter = N''               OR (                      (u.first_name + N' ' + u.last_name) LIKE '%' + @UserNameFilter + '%'                   OR u.first_name LIKE '%' + @UserNameFilter + '%'                   OR u.last_name  LIKE '%' + @UserNameFilter + '%'                   OR u.email      LIKE '%' + @UserNameFilter + '%'                  )              )            -- Filtro por proyecto          AND (@ProjectId IS NULL OR rd.project_id = @ProjectId)            -- Filtro por tipo          AND (@Type   IS NULL OR rd.type   = @Type)            -- Filtro por estado          AND (@Status IS NULL OR rd.status = @Status)            -- Filtro por rango de fechas (effective_date)          AND (@FromDate IS NULL OR rd.effective_date >= @FromDate)          AND (@ToDate   IS NULL OR rd.effective_date <= @ToDate)      ORDER BY          rd.effective_date DESC,          rd.created_at     DESC;  END;  
GO    CREATE   PROCEDURE dbo.sp_RefundsDeductions_UpdateStatus  (      @RefundDeductionId UNIQUEIDENTIFIER,   -- Id del registro en dbo.refunds_deductions      @NewStatus         VARCHAR(50),        -- 'approved', 'rejected', 'pending', etc.      @UserEmail         VARCHAR(255)        -- quien realiza el cambio (para auditoría)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @RefundDeductionId IS NULL      BEGIN          RAISERROR('RefundDeductionId es obligatorio.', 16, 1);          RETURN;      END;        IF @NewStatus IS NULL OR LTRIM(RTRIM(@NewStatus)) = ''      BEGIN          RAISERROR('NewStatus es obligatorio.', 16, 1);          RETURN;      END;        IF @UserEmail IS NULL OR LTRIM(RTRIM(@UserEmail)) = ''      BEGIN          RAISERROR('UserEmail es obligatorio.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Resolver el usuario que actualiza (approved_by / updated_by)      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM dbo.users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Actualizar el registro      --    - status      --    - approved_by / approved_at solo si pasa a "approved"      --    - updated_at / updated_by siempre      -------------------------------------------------------------------      DECLARE @Now DATETIME2 = SYSDATETIME();        UPDATE rd      SET           rd.status     = @NewStatus,          rd.approved_by = CASE                               WHEN LOWER(@NewStatus) = 'approved' THEN @UserId                              ELSE rd.approved_by                           END,          rd.approved_at = CASE                               WHEN LOWER(@NewStatus) = 'approved' THEN @Now                              ELSE rd.approved_at                           END,          rd.updated_at = @Now,          rd.updated_by = @UserId      FROM dbo.refunds_deductions rd      WHERE rd.id = @RefundDeductionId;        -------------------------------------------------------------------      -- 4. Devolver el registro actualizado (igual patrón que expenses)      -------------------------------------------------------------------      SELECT           rd.id              AS refund_deduction_id,          rd.user_id,          u.first_name + N' ' + u.last_name AS user_full_name,          u.email                            AS user_email,            rd.project_id,          p.name                             AS project_name,          p.code                             AS project_code,            rd.type,          rd.description,          rd.amount,          rd.currency,          rd.effective_date,          rd.status,            rd.approved_by,          au.first_name + N' ' + au.last_name AS approved_by_name,          rd.approved_at,            rd.rejection_reason,          rd.applied_at,          rd.payroll_reference,          rd.notes,            rd.is_active,          rd.created_at,          rd.updated_at,          rd.created_by,          rd.updated_by      FROM dbo.refunds_deductions rd      INNER JOIN dbo.users    u  ON u.id  = rd.user_id      INNER JOIN dbo.projects p  ON p.id  = rd.project_id      LEFT  JOIN dbo.users    au ON au.id = rd.approved_by      WHERE rd.id = @RefundDeductionId;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_Report_DailyHoursByUser]  (      @FromDate DATE,      @ToDate   DATE  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Diferencia horaria NY–UTC (tabla NYUTC)      -------------------------------------------------------------------      DECLARE @TimeDiff INT;        SELECT TOP 1 @TimeDiff = timediff      FROM dbo.NYUTC;        IF @TimeDiff IS NULL          SET @TimeDiff = -5; -- respaldo        -------------------------------------------------------------------      -- 3. Base: horas por usuario y día NY      -------------------------------------------------------------------      ;WITH Base AS      (          SELECT              u.id                              AS user_id,              u.first_name + N' ' + u.last_name AS NAME,              CAST(                  DATEADD(HOUR, @TimeDiff, te.clock_in_time)                  AS DATE              ) AS work_date_ny,              DATENAME(                  WEEKDAY,                  DATEADD(HOUR, @TimeDiff, te.clock_in_time)              ) AS day_of_week,              te.billable_hours          FROM dbo.time_entries te          INNER JOIN dbo.users u              ON u.id = te.user_id          WHERE              te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND te.billable_hours IS NOT NULL              AND te.billable_hours > 0              AND CAST(                      DATEADD(HOUR, @TimeDiff, te.clock_in_time)                      AS DATE                  ) >= @FromDate              AND CAST(                      DATEADD(HOUR, @TimeDiff, te.clock_in_time)                      AS DATE                  ) <= @ToDate      ),      Agg AS      (          SELECT              NAME,              day_of_week,              SUM(billable_hours) AS hours          FROM Base          GROUP BY              NAME,              day_of_week      )      -------------------------------------------------------------------      -- 4. Resumen final: columnas fijas Domingo–Sábado + Total      -------------------------------------------------------------------      SELECT          a.NAME,            CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Sunday'    THEN a.hours END), 0) AS DECIMAL(10,2)) AS Sunday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Monday'    THEN a.hours END), 0) AS DECIMAL(10,2)) AS Monday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Tuesday'   THEN a.hours END), 0) AS DECIMAL(10,2)) AS Tuesday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Wednesday' THEN a.hours END), 0) AS DECIMAL(10,2)) AS Wednesday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Thursday'  THEN a.hours END), 0) AS DECIMAL(10,2)) AS Thursday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Friday'    THEN a.hours END), 0) AS DECIMAL(10,2)) AS Friday,          CAST(ISNULL(SUM(CASE WHEN a.day_of_week = 'Saturday'  THEN a.hours END), 0) AS DECIMAL(10,2)) AS Saturday,            CAST(ISNULL(SUM(a.hours), 0) AS DECIMAL(10,2)) AS TotalHours      FROM Agg a      GROUP BY          a.NAME      ORDER BY          a.NAME;  END;  
GO    CREATE   PROCEDURE dbo.sp_ReportAttachmentsDeactivateByIdsCsv  (      @IdsCsv VARCHAR(MAX)   -- lista de GUIDs separados por comas  )  AS  BEGIN      SET NOCOUNT ON;        ;WITH ParsedIds AS      (          SELECT TRY_CAST(value AS UNIQUEIDENTIFIER) AS id          FROM STRING_SPLIT(@IdsCsv, ',')      )      UPDATE na      SET na.is_active = 0      FROM dbo.note_attachments na      INNER JOIN ParsedIds p          ON na.id = p.id      WHERE p.id IS NOT NULL;  END;  
GO  CREATE PROCEDURE [dbo].[sp_TimeEntry_CheckIn]  (      @UserEmail          VARCHAR(255),      @ProjectId          UNIQUEIDENTIFIER,      @EntryTypeCode      VARCHAR(50) = 'regular',  -- regular / overtime / etc.      @ClockInLatitude    DECIMAL(10,8) = NULL,      @ClockInLongitude   DECIMAL(11,8) = NULL,      @ClockInAddress     NVARCHAR(500) = NULL,      @ClockInPhotoUrl    VARCHAR(500) = NULL,      @ClockInDeviceInfo  NVARCHAR(255) = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Validar que no tenga una entrada abierta en NINGÚN proyecto      -------------------------------------------------------------------      DECLARE           @Today       DATE       = CAST(GETUTCDATE() AS DATE)   DECLARE          @StartOfDay  DATETIME2  = CAST(@Today AS DATETIME2)   DECLARE          @EndOfDay    DATETIME2  = DATEADD(DAY, 1, CAST(@Today AS DATETIME2));        IF EXISTS (          SELECT 1          FROM time_entries te          WHERE te.user_id = @UserId            AND te.is_active = 1            AND te.clock_in_time >= @StartOfDay            AND te.clock_in_time <  @EndOfDay            AND te.clock_out_time IS NULL      )      BEGIN          RAISERROR('Ya existe una marcación abierta para este usuario en el día de hoy. Debe marcar salida antes de un nuevo ingreso.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 3. Tomar tipo de marcación y tarifa por hora      -------------------------------------------------------------------      DECLARE @EntryTypeId INT;        SELECT @EntryTypeId = id      FROM time_entry_types      WHERE code = @EntryTypeCode        AND is_active = 1;        IF @EntryTypeId IS NULL      BEGIN          RAISERROR('Tipo de marcación no válido.', 16, 1);          RETURN;      END        -- Tarifa base: primero buscar en project_assignments, si no hay, usar hourly_rate de users      DECLARE @HourlyRate DECIMAL(10,2);        SELECT TOP (1)           @HourlyRate = pa.hourly_rate      FROM project_assignments pa      WHERE           pa.project_id = @ProjectId          AND pa.user_id = @UserId          AND pa.is_active = 1      ORDER BY pa.assigned_date DESC;        IF @HourlyRate IS NULL      BEGIN          SELECT @HourlyRate = hourly_rate          FROM users          WHERE id = @UserId;      END        IF @HourlyRate IS NULL          SET @HourlyRate = 0; -- fallback seguro        -------------------------------------------------------------------      -- 4. Insertar nueva entrada (SIEMPRE EN UTC)      -------------------------------------------------------------------      DECLARE @NowUtc DATETIME2 = SYSUTCDATETIME();      DECLARE @NewEntryId UNIQUEIDENTIFIER = NEWID();        INSERT INTO time_entries (          id,          project_id,          user_id,          entry_type_id,          clock_in_time,          clock_in_latitude,          clock_in_longitude,          clock_in_address,          clock_in_photo_url,          clock_in_device_info,          break_minutes,          billable_hours,          hourly_rate,          status,          notes,          created_at,          created_by,          updated_at,          updated_by,          is_active      )      VALUES (          @NewEntryId,          @ProjectId,          @UserId,          @EntryTypeId,          @NowUtc,          @ClockInLatitude,          @ClockInLongitude,          @ClockInAddress,          @ClockInPhotoUrl,          @ClockInDeviceInfo,          0,          -- break_minutes          NULL,       -- billable_hours          @HourlyRate,          'pending',  -- status inicial          NULL,       -- notes          @NowUtc,          @UserId,          @NowUtc,          @UserId,          1      );        -------------------------------------------------------------------      -- 5. Devolver la fila insertada con datos de proyecto      --    Incluimos columnas convertidas a hora de Nueva York      -------------------------------------------------------------------      SELECT           te.id              AS time_entry_id,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.user_id,          u.email            AS user_email,            -- Horas en UTC (crudas, por si las necesitas)          te.clock_in_time,          te.clock_out_time,            -- Horas convertidas a New York (maneja DST automáticamente)          CAST(              te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'              AS DATETIME2(0)          ) AS clock_in_time_ny,          CAST(              te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'              AS DATETIME2(0)          ) AS clock_out_time_ny,            te.hourly_rate,          te.billable_hours,          te.total_hours,          te.total_amount,          te.status      FROM time_entries te      INNER JOIN projects p ON p.id = te.project_id      INNER JOIN users   u  ON u.id = te.user_id      WHERE te.id = @NewEntryId;  END;  
GO    CREATE PROCEDURE [dbo].[sp_TimeEntry_CheckOut]  (      @UserEmail          VARCHAR(255),      @ClockOutLatitude   DECIMAL(10,8)  = NULL,      @ClockOutLongitude  DECIMAL(11,8)  = NULL,      @ClockOutAddress    NVARCHAR(500)  = NULL,      @ClockOutPhotoUrl   VARCHAR(500)   = NULL,      @ClockOutDeviceInfo NVARCHAR(255)  = NULL,      @BreakMinutes       INT            = NULL     -- opcional: pausa  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Última entrada ABIERTA      -------------------------------------------------------------------      DECLARE           @OpenEntryId     UNIQUEIDENTIFIER,          @ClockInTime     DATETIME2,          @HourlyRate      DECIMAL(10,2),          @ExistingBreak   INT;        SELECT TOP (1)          @OpenEntryId   = te.id,          @ClockInTime   = te.clock_in_time,          @HourlyRate    = te.hourly_rate,          @ExistingBreak = te.break_minutes      FROM time_entries te      WHERE           te.user_id = @UserId          AND te.is_active = 1          AND te.clock_out_time IS NULL      -- SOLO entradas abiertas      ORDER BY te.clock_in_time DESC;        -- la más reciente        IF @OpenEntryId IS NULL      BEGIN          RAISERROR('No se encontró una marcación abierta para este usuario.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Cálculos SIN REDONDEO (por minuto)      -------------------------------------------------------------------      DECLARE           @NowUtc          DATETIME2 = SYSUTCDATETIME(),          @BreakToUse      INT,          @TotalMinutes    INT,          @TotalHours      DECIMAL(10,2),          @BillableMinutes INT,          @BillableHours   DECIMAL(10,2),          @TotalAmount     DECIMAL(10,2);        -- Pausa a usar      SET @BreakToUse = ISNULL(@BreakMinutes, ISNULL(@ExistingBreak, 0));        -- Minutos totales trabajados      SET @TotalMinutes = DATEDIFF(MINUTE, @ClockInTime, @NowUtc);        -- Horas totales trabajadas (sin pausa)      SET @TotalHours = CAST(@TotalMinutes / 60.0 AS DECIMAL(10,2));        -- Minutos pagables = totales - pausa (no negativos)      SET @BillableMinutes = @TotalMinutes - @BreakToUse;      IF @BillableMinutes < 0 SET @BillableMinutes = 0;        -- Horas pagables SIN redondeo (cada minuto cuenta)      SET @BillableHours = CAST(@BillableMinutes / 60.0 AS DECIMAL(10,2));        -- Monto total (no se guarda si total_amount es calculado, pero lo usamos para devolverlo)      SET @TotalAmount = CAST(@BillableHours * ISNULL(@HourlyRate, 0) AS DECIMAL(10,2));        -------------------------------------------------------------------      -- 4. UPDATE (sin tocar total_hours ni total_amount)      -------------------------------------------------------------------      UPDATE te      SET           te.clock_out_time        = @NowUtc,          te.clock_out_latitude    = @ClockOutLatitude,          te.clock_out_longitude   = @ClockOutLongitude,          te.clock_out_address     = @ClockOutAddress,          te.clock_out_photo_url   = @ClockOutPhotoUrl,          te.clock_out_device_info = @ClockOutDeviceInfo,          te.break_minutes         = @BreakToUse,          te.billable_hours        = @BillableHours,          te.status                = 'pending',          te.updated_at            = @NowUtc,          te.updated_by            = @UserId      FROM time_entries te      WHERE te.id = @OpenEntryId;        -------------------------------------------------------------------      -- 5. Devolver fila actualizada      --    total_hours y total_amount vendrán de sus columnas (posible computed),      --    pero también devolvemos @TotalHours/@TotalAmount por si quieres usarlos.      -------------------------------------------------------------------      SELECT           te.id              AS time_entry_id,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.user_id,          u.email            AS user_email,          te.clock_in_time,          te.clock_out_time,          te.break_minutes,          te.hourly_rate,          te.billable_hours,          te.total_hours,           -- columna de la tabla (puede ser calculada)          te.total_amount,          -- columna de la tabla (puede ser calculada)          @TotalHours   AS calc_total_hours_no_rounding,          @TotalAmount  AS calc_total_amount_no_rounding,          te.status      FROM time_entries te      INNER JOIN projects p ON p.id = te.project_id      INNER JOIN users   u  ON u.id = te.user_id      WHERE te.id = @OpenEntryId;  END;  
GO  CREATE   PROCEDURE [dbo].[sp_TimeEntry_CreateManual]  (      @ProjectId    UNIQUEIDENTIFIER,      @UserId       UNIQUEIDENTIFIER,      @ClockInNy    DATETIME2(0),      @ClockOutNy   DATETIME2(0) = NULL,      @Notes        NVARCHAR(MAX),      @AdminEmail   VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 0. Resolver AdminId desde AdminEmail      -------------------------------------------------------------------      DECLARE @AdminId UNIQUEIDENTIFIER;        SELECT @AdminId = id      FROM dbo.users      WHERE email = @AdminEmail        AND is_active = 1;        IF @AdminId IS NULL      BEGIN          RAISERROR('AdminEmail no corresponde a un usuario activo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @ProjectId IS NULL      BEGIN          RAISERROR('ProjectId es obligatorio.', 16, 1);          RETURN;      END;        IF @UserId IS NULL      BEGIN          RAISERROR('UserId es obligatorio.', 16, 1);          RETURN;      END;        IF @ClockInNy IS NULL      BEGIN          RAISERROR('ClockInNy es obligatorio.', 16, 1);          RETURN;      END;        IF @ClockOutNy IS NOT NULL AND @ClockOutNy <= @ClockInNy      BEGIN          RAISERROR('ClockOutNy debe ser mayor que ClockInNy cuando se especifica.', 16, 1);          RETURN;      END;        IF @Notes IS NULL OR LTRIM(RTRIM(@Notes)) = ''      BEGIN          RAISERROR('Notes (justificación) es obligatorio para asistencias manuales.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Obtener hourly_rate desde project_assignments (en dos pasos)      -------------------------------------------------------------------      DECLARE @HourlyRate DECIMAL(10,2),              @AssignmentsCount INT;        -- 2.1 Contar asignaciones activas      SELECT @AssignmentsCount = COUNT(*)      FROM dbo.project_assignments pa      WHERE           pa.project_id = @ProjectId          AND pa.user_id = @UserId          AND pa.is_active = 1;        IF @AssignmentsCount IS NULL OR @AssignmentsCount = 0      BEGIN          RAISERROR('No existe una asignación activa en project_assignments para este usuario y proyecto.', 16, 1);          RETURN;      END;        IF @AssignmentsCount > 1      BEGIN          RAISERROR('Existe más de una asignación activa en project_assignments para este usuario y proyecto.', 16, 1);          RETURN;      END;        -- 2.2 Traer el hourly_rate de esa única fila      SELECT TOP 1 @HourlyRate = pa.hourly_rate      FROM dbo.project_assignments pa      WHERE           pa.project_id = @ProjectId          AND pa.user_id = @UserId          AND pa.is_active = 1;        IF @HourlyRate IS NULL OR @HourlyRate <= 0      BEGIN          RAISERROR('El hourly_rate en project_assignments debe ser mayor que 0.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Convertir horas NY -> UTC      -------------------------------------------------------------------      DECLARE @ClockInUtc  DATETIME2(0),              @ClockOutUtc DATETIME2(0) = NULL;        SET @ClockInUtc = CAST(                          @ClockInNy AT TIME ZONE 'Eastern Standard Time'                                    AT TIME ZONE 'UTC'                        AS DATETIME2(0));        IF @ClockOutNy IS NOT NULL      BEGIN          SET @ClockOutUtc = CAST(                              @ClockOutNy AT TIME ZONE 'Eastern Standard Time'                                         AT TIME ZONE 'UTC'                            AS DATETIME2(0));      END;        -------------------------------------------------------------------      -- 4. Cálculos de tiempo (sin redondeo)      -------------------------------------------------------------------      DECLARE          @NowUtc          DATETIME2(0)   = SYSUTCDATETIME(),          @BreakMinutes    INT            = 0,          @TotalMinutes    INT            = NULL,          @BillableMinutes INT            = NULL,          @BillableHours   DECIMAL(10,2)  = NULL;        IF @ClockOutUtc IS NOT NULL      BEGIN          SET @TotalMinutes = DATEDIFF(MINUTE, @ClockInUtc, @ClockOutUtc);            SET @BillableMinutes = @TotalMinutes - ISNULL(@BreakMinutes, 0);          IF @BillableMinutes < 0 SET @BillableMinutes = 0;            SET @BillableHours = CAST(@BillableMinutes / 60.0 AS DECIMAL(10,2));      END;        -------------------------------------------------------------------      -- 5. Insert en time_entries      -------------------------------------------------------------------      DECLARE @NewId UNIQUEIDENTIFIER = NEWID();        INSERT INTO dbo.time_entries      (          id,          project_id,          user_id,          entry_type_id,          clock_in_time,          clock_in_latitude,          clock_in_longitude,          clock_in_address,          clock_in_photo_url,          clock_in_device_info,          clock_out_time,          clock_out_latitude,          clock_out_longitude,          clock_out_address,          clock_out_photo_url,          clock_out_device_info,          break_minutes,          billable_hours,          hourly_rate,          status,          notes,          approved_by,          approved_at,          is_active,          created_at,          created_by,          updated_at,          updated_by      )      VALUES      (          @NewId,          @ProjectId,          @UserId,          1,          @ClockInUtc,          NULL, NULL, NULL, NULL, NULL,          @ClockOutUtc,          NULL, NULL, NULL, NULL, NULL,          @BreakMinutes,          @BillableHours,          @HourlyRate,          CASE               WHEN @ClockOutUtc IS NULL THEN 'open'              ELSE 'approved'          END,          @Notes,          CASE WHEN @ClockOutUtc IS NULL THEN NULL ELSE @AdminId END,          CASE WHEN @ClockOutUtc IS NULL THEN NULL ELSE @NowUtc END,          1,          @NowUtc,          @AdminId,          @NowUtc,          @AdminId      );        -------------------------------------------------------------------      -- 6. Devolver la fila creada      -------------------------------------------------------------------      SELECT          te.id              AS time_entry_id,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.user_id,          u.first_name + ' ' + u.last_name AS user_full_name,          te.clock_in_time,          te.clock_out_time,          te.billable_hours,          te.hourly_rate,          te.status,          te.notes      FROM dbo.time_entries te      INNER JOIN dbo.projects p ON p.id = te.project_id      INNER JOIN dbo.users   u ON u.id = te.user_id      WHERE te.id = @NewId;  END;  
GO    CREATE   PROCEDURE dbo.sp_TimeEntry_Deactivate  (      @TimeEntryId   UNIQUEIDENTIFIER,      @UserEmail     VARCHAR(255) = NULL ,  -- opcional, para auditoría (updated_by)   @Notes   VARCHAR(255)  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @TimeEntryId IS NULL      BEGIN          RAISERROR('TimeEntryId es obligatorio.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Resolver usuario que actualiza (si se envía email)      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER = NULL;        IF @UserEmail IS NOT NULL AND LTRIM(RTRIM(@UserEmail)) <> ''      BEGIN          SELECT @UserId = id          FROM dbo.users          WHERE email = @UserEmail            AND is_active = 1;      END;        DECLARE @NowUtc DATETIME2 = SYSUTCDATETIME();        -------------------------------------------------------------------      -- 3. Desactivar registro      -------------------------------------------------------------------      UPDATE te      SET           te.is_active = 0,          te.updated_at = @NowUtc,          te.updated_by = ISNULL(@UserId, te.updated_by),    te.notes_edit = @Notes      FROM dbo.time_entries te      WHERE te.id = @TimeEntryId;        -------------------------------------------------------------------      -- 4. Devolver el registro actualizado      -------------------------------------------------------------------      SELECT           te.id              AS time_entry_id,          te.user_id,          u.email            AS user_email,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.clock_in_time,          te.clock_out_time,          te.billable_hours,          te.hourly_rate,          te.total_amount,          te.is_active,          te.created_at,          te.updated_at,          te.created_by,          te.updated_by      FROM dbo.time_entries te      LEFT JOIN dbo.users    u ON u.id = te.user_id      LEFT JOIN dbo.projects p ON p.id = te.project_id      WHERE te.id = @TimeEntryId;  END;  
GO    CREATE PROCEDURE [dbo].[sp_TimeEntry_GetUserHistory]  (      @UserEmail VARCHAR(255),      @FromDate  DATE,      @ToDate    DATE,      @ProjectId UNIQUEIDENTIFIER = NULL  -- opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones      -------------------------------------------------------------------      IF @UserEmail IS NULL OR LTRIM(RTRIM(@UserEmail)) = ''      BEGIN          RAISERROR('UserEmail es obligatorio.', 16, 1);          RETURN;      END;        IF @FromDate IS NULL OR @ToDate IS NULL      BEGIN          RAISERROR('FromDate y ToDate son obligatorios.', 16, 1);          RETURN;      END;        IF @FromDate > @ToDate      BEGIN          RAISERROR('FromDate no puede ser mayor que ToDate.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Usuario y "hoy" en zona New York      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM dbo.users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- sin filas, pero columnas definidas          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS time_entry_id,              CAST(NULL AS UNIQUEIDENTIFIER) AS project_id,              CAST(NULL AS NVARCHAR(200))    AS project_name,              CAST(NULL AS VARCHAR(50))      AS project_code,              CAST(NULL AS VARCHAR(50))      AS project_state,              CAST(NULL AS VARCHAR(50))      AS project_city,              CAST(NULL AS NVARCHAR(200))    AS user_full_name,                CAST(NULL AS DATETIME2)        AS clock_in_time_utc,              CAST(NULL AS DATETIME2)        AS clock_out_time_utc,              CAST(NULL AS DATETIME2)        AS clock_in_time_ny,              CAST(NULL AS DATETIME2)        AS clock_out_time_ny,              CAST(NULL AS NVARCHAR(20))     AS work_date_ny,                CAST(NULL AS DECIMAL(10,8))    AS clock_in_latitude,              CAST(NULL AS DECIMAL(11,8))    AS clock_in_longitude,              CAST(NULL AS VARCHAR(500))     AS clock_in_photo_url,              CAST(NULL AS DECIMAL(10,8))    AS clock_out_latitude,              CAST(NULL AS DECIMAL(11,8))    AS clock_out_longitude,              CAST(NULL AS VARCHAR(500))     AS clock_out_photo_url,                CAST(NULL AS INT)              AS break_minutes,              CAST(NULL AS NVARCHAR(50))     AS worked_time_label,              CAST(NULL AS NVARCHAR(50))     AS billable_time_label,              CAST(NULL AS DECIMAL(10,2))    AS billable_hours,              CAST(NULL AS DECIMAL(10,2))    AS hourly_rate,              CAST(NULL AS DECIMAL(18,4))    AS total_amount,              CAST(NULL AS NVARCHAR(20))     AS status_label;          RETURN;      END;        DECLARE @NowUtc DATETIME2 = SYSUTCDATETIME();      DECLARE @NowNy  DATETIME2 = CAST(                                  @NowUtc AT TIME ZONE 'UTC'                                          AT TIME ZONE 'Eastern Standard Time'                                AS DATETIME2);      DECLARE @TodayNy DATE = CAST(@NowNy AS DATE);        -------------------------------------------------------------------      -- 3. CTE base: todas las entradas del usuario en el rango (según fecha NY)      -------------------------------------------------------------------      ;WITH Base AS      (          SELECT              te.id                AS time_entry_id,              te.project_id,              p.name               AS project_name,              p.code               AS project_code,     p.state              AS project_state,     p.city               AS project_city,                u.first_name + N' ' + u.last_name AS user_full_name,                te.clock_in_time     AS clock_in_time_utc,              te.clock_out_time    AS clock_out_time_utc,                -- coordenadas y fotos              te.clock_in_latitude,              te.clock_in_longitude,              te.clock_in_photo_url,              te.clock_out_latitude,              te.clock_out_longitude,              te.clock_out_photo_url,                -- horas convertidas a NY              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_in_time_ny,              CAST(                  te.clock_out_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATETIME2(0)              ) AS clock_out_time_ny,                -- fecha de trabajo en NY (para filtrar)              CAST(                  te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                  AS DATE              ) AS work_date_ny,                te.break_minutes,              te.billable_hours,              te.hourly_rate,              te.total_amount,              te.is_active,              te.status          FROM dbo.time_entries te          INNER JOIN dbo.projects p ON p.id = te.project_id          INNER JOIN dbo.users   u ON u.id = te.user_id          WHERE               te.user_id = @UserId              AND te.is_active = 1              AND CAST(                      te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                      AS DATE                  ) >= @FromDate              AND CAST(                      te.clock_in_time AT TIME ZONE 'UTC' AT TIME ZONE 'Eastern Standard Time'                      AS DATE                  ) <= @ToDate              AND (@ProjectId IS NULL OR te.project_id = @ProjectId)      )      -------------------------------------------------------------------      -- 4. Resultado final con textos y estado      -------------------------------------------------------------------      SELECT          b.time_entry_id,          b.project_id,          b.project_name,          b.project_code,    b.project_city,    b.project_state,          b.user_full_name,            b.clock_in_time_utc,          b.clock_out_time_utc,          b.clock_in_time_ny,          b.clock_out_time_ny,              CONVERT(NVARCHAR(10), b.work_date_ny, 120) AS work_date_ny, -- yyyy-MM-dd            b.clock_in_latitude,          b.clock_in_longitude,          b.clock_in_photo_url,          b.clock_out_latitude,          b.clock_out_longitude,          b.clock_out_photo_url,            b.break_minutes,            -- Horas trabajadas (crudas) como texto Xh Ym          CASE               WHEN b.clock_out_time_utc IS NULL                  THEN                      CONCAT(                          DATEDIFF(MINUTE, b.clock_in_time_utc, @NowUtc) / 60, N'h ',                          DATEDIFF(MINUTE, b.clock_in_time_utc, @NowUtc) % 60, N'm'                      )              ELSE                  CONCAT(                      DATEDIFF(MINUTE, b.clock_in_time_utc, b.clock_out_time_utc) / 60, N'h ',                      DATEDIFF(MINUTE, b.clock_in_time_utc, b.clock_out_time_utc) % 60, N'm'                  )          END AS worked_time_label,            -- Horas pagables (desde billable_hours) como texto Xh Ym          CASE               WHEN b.billable_hours IS NULL                  THEN NULL              ELSE                  CONCAT(                      FLOOR(b.billable_hours), N'h ',                      CAST( (b.billable_hours - FLOOR(b.billable_hours)) * 60 AS INT), N'm'                  )          END AS billable_time_label,            b.billable_hours,          b.hourly_rate,          b.total_amount,            -- Estado de la marcación          CASE               WHEN b.clock_out_time_utc IS NULL AND b.work_date_ny = @TodayNy                  THEN N'En sitio'              WHEN b.clock_out_time_utc IS NULL AND b.work_date_ny < @TodayNy                  THEN N'Sin cerrar'              ELSE N'Finalizada'          END AS status_label      FROM Base b      ORDER BY          b.work_date_ny DESC,          b.clock_in_time_utc DESC;  END;  
GO    CREATE PROCEDURE [dbo].[sp_TimeEntry_GetWeeklyHistory]  (      @UserEmail     VARCHAR(255),      @ReferenceDate DATE = NULL,   -- compatibilidad      @FromDate      DATE = NULL,   -- fecha inicial opcional      @ToDate        DATE = NULL    -- fecha final opcional  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Obtener usuario      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          -- Usuario no encontrado: devolvemos resultset vacío con la forma final          SELECT              CAST(NULL AS UNIQUEIDENTIFIER) AS time_entry_id,              CAST(NULL AS DATE)             AS entry_date,              CAST(NULL AS NVARCHAR(20))     AS day_of_week,              CAST(NULL AS DATETIME2(7))     AS clock_in_time,              CAST(NULL AS DATETIME2(7))     AS clock_out_time,              CAST(NULL AS NVARCHAR(200))    AS project_display_name,              CAST(NULL AS NVARCHAR(200))    AS project_color,              CAST(NULL AS DECIMAL(10,2))    AS rate_per_hour,              CAST(NULL AS DECIMAL(10,2))    AS total_hours,              CAST(NULL AS DECIMAL(10,2))    AS total_amount          WHERE 1 = 0;          RETURN;      END;        -------------------------------------------------------------------      -- 1.b Obtener diferencia horaria NY–UTC desde tabla NYUTC      -------------------------------------------------------------------      DECLARE @TimeDiff INT;        SELECT TOP 1 @TimeDiff = timediff      FROM dbo.NYUTC;        IF @TimeDiff IS NULL          SET @TimeDiff = -5; -- valor de respaldo si la tabla estuviera vacía        -------------------------------------------------------------------      -- 2. Rango de fechas (en términos de fecha NY)      -------------------------------------------------------------------      DECLARE @BaseDate DATE;        IF @FromDate IS NOT NULL AND @ToDate IS NOT NULL      BEGIN          SET @BaseDate = NULL; -- no se usa      END      ELSE      BEGIN          IF @ReferenceDate IS NULL              SET @BaseDate = CAST(GETUTCDATE() AS DATE);          ELSE              SET @BaseDate = @ReferenceDate;            -- Semana LUN-DOM          SET DATEFIRST 1; -- 1 = Monday            DECLARE @Dow INT = DATEPART(WEEKDAY, @BaseDate); -- 1..7 (lun..dom)            SET @FromDate = DATEADD(DAY, 1-@Dow, @BaseDate); -- lunes          SET @ToDate   = DATEADD(DAY, 7-@Dow, @BaseDate); -- domingo      END;        -------------------------------------------------------------------      -- 3. Historial de marcaciones (sin agrupar), usando fecha NY      -------------------------------------------------------------------      ;WITH Entries AS      (          SELECT              te.id,              te.user_id,                -- Fecha de la marcación según horario NY              CAST(DATEADD(HOUR, @TimeDiff, te.clock_in_time) AS DATE) AS entry_date_ny,                te.clock_in_time,              te.clock_out_time,              te.billable_hours,              te.hourly_rate,              te.total_amount,              te.project_id          FROM time_entries te          WHERE               te.user_id       = @UserId              AND te.is_active = 1              AND te.clock_out_time IS NOT NULL              AND te.billable_hours IS NOT NULL              AND te.billable_hours > 0              AND CAST(DATEADD(HOUR, @TimeDiff, te.clock_in_time) AS DATE) >= @FromDate              AND CAST(DATEADD(HOUR, @TimeDiff, te.clock_in_time) AS DATE) <= @ToDate      )      SELECT          e.id                                AS time_entry_id,          e.entry_date_ny                     AS entry_date,          DATENAME(WEEKDAY, e.entry_date_ny)  AS day_of_week,        -- día según NY          e.clock_in_time,          e.clock_out_time,          CONCAT(pr.code, ' - ', pr.name)    AS project_display_name,          pr.color                           AS project_color,          CAST(e.hourly_rate   AS DECIMAL(10,2)) AS rate_per_hour,          CAST(e.billable_hours AS DECIMAL(10,2)) AS total_hours,          CAST(e.total_amount  AS DECIMAL(10,2)) AS total_amount      FROM Entries e      INNER JOIN projects pr          ON pr.id = e.project_id      ORDER BY          e.entry_date_ny DESC,      -- día más reciente primero (según NY)          e.clock_in_time DESC;      -- dentro del día, la última marcación primero  END;  
GO    CREATE   PROCEDURE [dbo].[sp_TimeEntry_UpdateBreakMinutes]  (      @TimeEntryId   UNIQUEIDENTIFIER,      @BreakMinutes  INT  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @TimeEntryId IS NULL      BEGIN          RAISERROR('TimeEntryId es obligatorio.', 16, 1);          RETURN;      END;        IF @BreakMinutes IS NULL OR @BreakMinutes < 0      BEGIN          RAISERROR('BreakMinutes debe ser mayor o igual a 0.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Traer datos actuales del time_entry (asumimos que tiene clock_out_time)      -------------------------------------------------------------------      DECLARE          @ClockInUtc   DATETIME2(0),          @ClockOutUtc  DATETIME2(0),          @NowUtc       DATETIME2(0) = SYSUTCDATETIME(),          @TotalMinutes INT,          @BillableMinutes INT,          @BillableHours  DECIMAL(10,2);        SELECT          @ClockInUtc  = te.clock_in_time,          @ClockOutUtc = te.clock_out_time      FROM dbo.time_entries te      WHERE te.id = @TimeEntryId        AND te.is_active = 1;        IF @ClockInUtc IS NULL OR @ClockOutUtc IS NULL      BEGIN          RAISERROR('El time_entry no existe, no está activo o no tiene clock_out_time.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Calcular billable_hours (sin redondeos)      -------------------------------------------------------------------      SET @TotalMinutes = DATEDIFF(MINUTE, @ClockInUtc, @ClockOutUtc);        SET @BillableMinutes = @TotalMinutes - @BreakMinutes;      IF @BillableMinutes < 0 SET @BillableMinutes = 0;        SET @BillableHours = CAST(@BillableMinutes / 60.0 AS DECIMAL(10,2));        -------------------------------------------------------------------      -- 4. Actualizar solo break_minutes y billable_hours      -------------------------------------------------------------------      UPDATE dbo.time_entries      SET          break_minutes  = @BreakMinutes,          billable_hours = @BillableHours,          updated_at     = @NowUtc      WHERE id = @TimeEntryId;        -------------------------------------------------------------------      -- 5. Devolver registro actualizado (opcional)      -------------------------------------------------------------------      SELECT          te.id              AS time_entry_id,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.user_id,          u.first_name + ' ' + u.last_name AS employee_name,          te.clock_in_time,          te.clock_out_time,          te.break_minutes,          te.billable_hours,          te.hourly_rate,          te.status,          te.notes      FROM dbo.time_entries te      INNER JOIN dbo.projects p ON p.id = te.project_id      INNER JOIN dbo.users   u ON u.id = te.user_id      WHERE te.id = @TimeEntryId;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_TimeEntry_UpdateManual]  (      @TimeEntryId UNIQUEIDENTIFIER,     -- id del registro a editar      @ProjectId   UNIQUEIDENTIFIER,      @UserId      UNIQUEIDENTIFIER,      @ClockInNy   DATETIME2(0),        -- check-in en horario NY (obligatorio)      @ClockOutNy  DATETIME2(0) = NULL, -- check-out en horario NY (opcional)      @Notes       NVARCHAR(MAX),       -- justificación de edición (obligatorio)      @AdminEmail  VARCHAR(255)         -- email de quien edita  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 0. Resolver AdminId desde AdminEmail      -------------------------------------------------------------------      DECLARE @AdminId UNIQUEIDENTIFIER;        SELECT @AdminId = id      FROM dbo.users      WHERE email = @AdminEmail        AND is_active = 1;        IF @AdminId IS NULL      BEGIN          RAISERROR('AdminEmail no corresponde a un usuario activo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 1. Validaciones básicas      -------------------------------------------------------------------      IF @TimeEntryId IS NULL      BEGIN          RAISERROR('TimeEntryId es obligatorio.', 16, 1);          RETURN;      END;        IF @ProjectId IS NULL      BEGIN          RAISERROR('ProjectId es obligatorio.', 16, 1);          RETURN;      END;        IF @UserId IS NULL      BEGIN          RAISERROR('UserId es obligatorio.', 16, 1);          RETURN;      END;        IF @ClockInNy IS NULL      BEGIN          RAISERROR('ClockInNy es obligatorio.', 16, 1);          RETURN;      END;        IF @ClockOutNy IS NOT NULL AND @ClockOutNy <= @ClockInNy      BEGIN          RAISERROR('ClockOutNy debe ser mayor que ClockInNy cuando se especifica.', 16, 1);          RETURN;      END;        IF @Notes IS NULL OR LTRIM(RTRIM(@Notes)) = ''      BEGIN          RAISERROR('Notes (justificación) es obligatorio para editar asistencias manuales.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 2. Verificar que exista el time_entry      -------------------------------------------------------------------      IF NOT EXISTS (          SELECT 1          FROM dbo.time_entries          WHERE id = @TimeEntryId            AND is_active = 1      )      BEGIN          RAISERROR('El time_entry especificado no existe o no está activo.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 3. Obtener hourly_rate desde project_assignments      -------------------------------------------------------------------      DECLARE @HourlyRate DECIMAL(10,2),              @AssignmentsCount INT;        -- 3.1 Contar asignaciones activas      SELECT @AssignmentsCount = COUNT(*)      FROM dbo.project_assignments pa      WHERE           pa.project_id = @ProjectId          AND pa.user_id = @UserId          AND pa.is_active = 1;        IF @AssignmentsCount IS NULL OR @AssignmentsCount = 0      BEGIN          RAISERROR('No existe una asignación activa en project_assignments para este usuario y proyecto.', 16, 1);          RETURN;      END;        IF @AssignmentsCount > 1      BEGIN          RAISERROR('Existe más de una asignación activa en project_assignments para este usuario y proyecto.', 16, 1);          RETURN;      END;        -- 3.2 Obtener hourly_rate      SELECT TOP 1 @HourlyRate = pa.hourly_rate      FROM dbo.project_assignments pa      WHERE           pa.project_id = @ProjectId          AND pa.user_id = @UserId          AND pa.is_active = 1;        IF @HourlyRate IS NULL OR @HourlyRate <= 0      BEGIN          RAISERROR('El hourly_rate en project_assignments debe ser mayor que 0.', 16, 1);          RETURN;      END;        -------------------------------------------------------------------      -- 4. Convertir horas NY -> UTC      -------------------------------------------------------------------      DECLARE @ClockInUtc  DATETIME2(0),              @ClockOutUtc DATETIME2(0) = NULL;        SET @ClockInUtc = CAST(                          @ClockInNy AT TIME ZONE 'Eastern Standard Time'                                    AT TIME ZONE 'UTC'                        AS DATETIME2(0));        IF @ClockOutNy IS NOT NULL      BEGIN          SET @ClockOutUtc = CAST(                              @ClockOutNy AT TIME ZONE 'Eastern Standard Time'                                         AT TIME ZONE 'UTC'                            AS DATETIME2(0));      END;        -------------------------------------------------------------------      -- 5. Recalcular billable_hours (sin redondeo)      -------------------------------------------------------------------      DECLARE          @NowUtc          DATETIME2(0)   = SYSUTCDATETIME(),          @BreakMinutes    INT            = 0,          @TotalMinutes    INT            = NULL,          @BillableMinutes INT            = NULL,          @BillableHours   DECIMAL(10,2)  = NULL,          @NewStatus       VARCHAR(50);        IF @ClockOutUtc IS NOT NULL      BEGIN          SET @TotalMinutes = DATEDIFF(MINUTE, @ClockInUtc, @ClockOutUtc);            SET @BillableMinutes = @TotalMinutes - ISNULL(@BreakMinutes, 0);          IF @BillableMinutes < 0 SET @BillableMinutes = 0;            SET @BillableHours = CAST(@BillableMinutes / 60.0 AS DECIMAL(10,2));          SET @NewStatus     = 'approved';      END      ELSE      BEGIN          -- Sigue abierta          SET @BillableHours = NULL;          SET @NewStatus     = 'open';      END;        -------------------------------------------------------------------      -- 6. UPDATE del registro (solo campos necesarios)      -------------------------------------------------------------------      UPDATE dbo.time_entries      SET          project_id     = @ProjectId,          user_id        = @UserId,          clock_in_time  = @ClockInUtc,          clock_out_time = @ClockOutUtc,          break_minutes  = @BreakMinutes,          billable_hours = @BillableHours,          hourly_rate    = @HourlyRate,          status         = @NewStatus,          notes_edit     = @Notes,          updated_at     = @NowUtc,          updated_by     = @AdminId      WHERE id = @TimeEntryId;        -------------------------------------------------------------------      -- 7. Devolver la fila actualizada      -------------------------------------------------------------------      SELECT          te.id              AS time_entry_id,          te.project_id,          p.code             AS project_code,          p.name             AS project_name,          te.user_id,          u.first_name + ' ' + u.last_name AS user_full_name,          te.clock_in_time,          te.clock_out_time,          te.billable_hours,          te.hourly_rate,          te.status,          te.notes_edit      FROM dbo.time_entries te      INNER JOIN dbo.projects p ON p.id = te.project_id      INNER JOIN dbo.users   u ON u.id = te.user_id      WHERE te.id = @TimeEntryId;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_UpdateExpenseStatus]  (      @ExpenseId  UNIQUEIDENTIFIER,      @NewStatus  VARCHAR(50),         -- 'approved' | 'rejected'      @UserEmail  VARCHAR(255),      @Comment    NVARCHAR(500) = NULL  )  AS  BEGIN      SET NOCOUNT ON;        -------------------------------------------------------------------      -- 1. Validar estado      -------------------------------------------------------------------      IF @NewStatus NOT IN ('approved', 'rejected')      BEGIN          RAISERROR('Estado de gasto inválido. Use ''approved'' o ''rejected''.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 2. Obtener usuario que aprueba/rechaza      -------------------------------------------------------------------      DECLARE @UserId UNIQUEIDENTIFIER;        SELECT @UserId = id      FROM dbo.users      WHERE email = @UserEmail        AND is_active = 1;        IF @UserId IS NULL      BEGIN          RAISERROR('Usuario no encontrado o inactivo para el email especificado.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 3. Validar que el gasto exista y esté activo      -------------------------------------------------------------------      IF NOT EXISTS (SELECT 1 FROM dbo.expenses WHERE id = @ExpenseId AND is_active = 1)      BEGIN          RAISERROR('Gasto no encontrado o inactivo.', 16, 1);          RETURN;      END        -------------------------------------------------------------------      -- 4. Actualizar estado del gasto      -------------------------------------------------------------------      UPDATE dbo.expenses      SET           status     = @NewStatus,          updated_at = SYSUTCDATETIME(),          updated_by = @UserId        WHERE id = @ExpenseId;        -------------------------------------------------------------------      -- 5. Devolver el registro actualizado (opcional, útil para refrescar galería)      -------------------------------------------------------------------      SELECT          e.id          AS expense_id,          e.status,          e.updated_at,          e.updated_by      FROM dbo.expenses e      WHERE e.id = @ExpenseId;  END;  
GO    CREATE   PROCEDURE [dbo].[sp_UpdateProject]      @id                  UNIQUEIDENTIFIER,      -- ID del proyecto a actualizar      @code                VARCHAR(50),      @name                NVARCHAR(200),      @client_email        VARCHAR(255),         -- correo del usuario logueado en PowerApps      @client_id           UNIQUEIDENTIFIER = NULL,      @description         NVARCHAR(MAX) = NULL,      @city                NVARCHAR(100),      @state               NVARCHAR(50),      @address             NVARCHAR(500),      @start_date          DATE,      @estimated_end_date  DATE = NULL,      @company             VARCHAR(50),      @status_id           INT = NULL,      @project_type_id     INT = NULL,      -- OPCIONALES:      @color               VARCHAR(50) = NULL,      @latitude            DECIMAL(10,8) = NULL,      @longitude           DECIMAL(11,8) = NULL,      @budget_hours        DECIMAL(10,2) = NULL,      @budget_amount       DECIMAL(15,2) = NULL,      @hourly_rate         DECIMAL(10,2) = NULL,      @is_active           BIT = 1,      @google_maps_link    NVARCHAR(500) = NULL,      @zipcode             NVARCHAR(20)  = NULL,      -- SALIDAS:      @success             BIT OUTPUT,      @message             NVARCHAR(400) OUTPUT  AS  BEGIN      SET NOCOUNT ON;        BEGIN TRY          -----------------------------------------------------          -- 0. Validar proyecto existente          -----------------------------------------------------          IF NOT EXISTS (SELECT 1 FROM dbo.projects WHERE id = @id)          BEGIN              SET @success = 0;              SET @message = N'No se encontró el proyecto especificado.';              RETURN;          END;            -----------------------------------------------------          -- 1. Buscar usuario por email (tabla dbo.users)          --    Este usuario será el updated_by          -----------------------------------------------------          DECLARE @updated_by UNIQUEIDENTIFIER;            SELECT @updated_by = u.id          FROM dbo.users u          WHERE u.email = @client_email            AND (u.is_active = 1 OR u.is_active IS NULL);            IF @updated_by IS NULL          BEGIN              SET @success = 0;              SET @message = N'No se encontró un usuario válido con el correo especificado.';              RETURN;          END;            -----------------------------------------------------          -- 2. Validar que el código no exista en OTRO proyecto          -----------------------------------------------------          IF EXISTS (              SELECT 1              FROM dbo.projects              WHERE code = @code                AND id <> @id          )          BEGIN              SET @success = 0;              SET @message = N'El código de proyecto ya existe en otro registro.';              RETURN;          END;            -----------------------------------------------------          -- 3. Actualizar el proyecto          -----------------------------------------------------          UPDATE dbo.projects          SET              code               = @code,              name               = @name,              description        = @description,              client_id          = @client_id,              status_id          = @status_id,              color              = @color,              address            = @address,              city               = @city,              latitude           = @latitude,              longitude          = @longitude,              start_date         = @start_date,              estimated_end_date = @estimated_end_date,              budget_hours       = @budget_hours,              budget_amount      = @budget_amount,              hourly_rate        = @hourly_rate,              is_active          = @is_active,              project_type_id    = @project_type_id,              state              = @state,              company            = @company,              google_maps_link   = @google_maps_link,              zipcode            = @zipcode,              updated_at         = SYSDATETIME(),              updated_by         = @updated_by          WHERE id = @id;            SET @success = 1;          SET @message = N'Proyecto actualizado correctamente.';      END TRY      BEGIN CATCH          SET @success = 0;          SET @message = ERROR_MESSAGE();      END CATCH;  END;  
GO    CREATE   PROCEDURE sp_VerificarCodigoProyecto      @CodigoProyecto  VARCHAR(50),      @Disponible      BIT OUTPUT,      @Mensaje         NVARCHAR(200) OUTPUT  AS  BEGIN      SET NOCOUNT ON;        IF EXISTS (          SELECT 1          FROM Projects          WHERE code = @CodigoProyecto      )      BEGIN          SET @Disponible = 0;          SET @Mensaje = N'El código de proyecto ya existe.';      END      ELSE      BEGIN          SET @Disponible = 1;          SET @Mensaje = N'El código de proyecto está disponible.';      END  END;  
GO  CREATE   PROCEDURE sp_VerificarNombreProyecto      @NombreProyecto  VARCHAR(50),      @Disponible      BIT OUTPUT,      @Mensaje         NVARCHAR(200) OUTPUT  AS  BEGIN      SET NOCOUNT ON;        IF EXISTS (          SELECT 1          FROM Projects          WHERE name = @NombreProyecto      )      BEGIN          SET @Disponible = 0;          SET @Mensaje = N'El nombre de proyecto ya existe.';      END      ELSE      BEGIN          SET @Disponible = 1;          SET @Mensaje = N'El nombre de proyecto está disponible.';      END  END;  
